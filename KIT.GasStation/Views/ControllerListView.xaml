<local:BaseView
    x:Class="KIT.GasStation.Views.ControllerListView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:Editors="clr-namespace:DevExpress.Xpf.Editors;assembly=DevExpress.Xpf.Core.v21.2"
    xmlns:behaviors="clr-namespace:KIT.GasStation.Behavior"
    xmlns:converters="clr-namespace:KIT.GasStation.Converters"
    xmlns:customControls="clr-namespace:KIT.GasStation.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:dx="http://schemas.devexpress.com/winfx/2008/xaml/core"
    xmlns:dxdo="http://schemas.devexpress.com/winfx/2008/xaml/docking"
    xmlns:dxmvvm="http://schemas.devexpress.com/winfx/2008/xaml/mvvm"
    xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
    xmlns:local="clr-namespace:KIT.GasStation.Views.Base"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:viewModels="clr-namespace:KIT.GasStation.ViewModels"
    d:DesignHeight="500"
    d:DesignWidth="600"
    Background="#EBEEF2"
    mc:Ignorable="d">

    <local:BaseView.Resources>
        <Style x:Key="ResizeThumbStyle" TargetType="Thumb">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Opacity" Value="0.01" />
            <Setter Property="Panel.ZIndex" Value="10" />
            <Setter Property="behaviors:ResizeOnCanvasBehavior.IsEnabled" Value="True" />
        </Style>
    </local:BaseView.Resources>

    <DockPanel>

        <ListBox
            HorizontalContentAlignment="Stretch"
            Background="Transparent"
            BorderThickness="0"
            ItemsSource="{Binding FuelDispenserViewModels}"
            ScrollViewer.HorizontalScrollBarVisibility="Disabled"
            ScrollViewer.VerticalScrollBarVisibility="Disabled"
            SelectedItem="{Binding SelectedFuelDispenser}">

            <ListBox.ItemsPanel>
                <ItemsPanelTemplate>
                    <Canvas />
                </ItemsPanelTemplate>
            </ListBox.ItemsPanel>

            <ListBox.ItemContainerStyle>
                <Style TargetType="ListBoxItem">
                    <Setter Property="Canvas.Left" Value="{Binding X}" />
                    <Setter Property="Canvas.Top" Value="{Binding Y}" />
                    <Setter Property="Width" Value="{Binding Width}" />
                    <Setter Property="Padding" Value="0" />
                    <Setter Property="FocusVisualStyle" Value="{x:Null}" />
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="ListBoxItem">
                                <ContentPresenter />
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </ListBox.ItemContainerStyle>

            <ListBox.ItemTemplate>
                <DataTemplate DataType="{x:Type viewModels:FuelDispenserViewModel}">
                    <Grid behaviors:DragOnCanvasBehavior.IsEnabled="True" Background="Transparent">
                        <Border
                            x:Name="MainBorder"
                            Padding="6"
                            Background="{StaticResource ControllerBackgroundColorBrush}"
                            BorderBrush="#AAA"
                            BorderThickness="1.5">
                            <Border.Effect>
                                <DropShadowEffect
                                    x:Name="MainShadow"
                                    BlurRadius="8"
                                    Direction="270"
                                    Opacity="0.12"
                                    ShadowDepth="2"
                                    Color="#000000" />
                            </Border.Effect>
                            <customControls:FuelTransferColumnControl
                                HorizontalAlignment="Stretch"
                                SnapsToDevicePixels="True"
                                UseLayoutRounding="True" />
                        </Border>

                        <!--  Стороны (ресайз)  -->
                        <Thumb
                            Width="6"
                            Height="Auto"
                            Margin="0,10"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Stretch"
                            behaviors:ResizeOnCanvasBehavior.Direction="Left"
                            Cursor="SizeWE"
                            Style="{StaticResource ResizeThumbStyle}" />

                        <Thumb
                            Width="6"
                            Height="Auto"
                            Margin="0,10"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Stretch"
                            behaviors:ResizeOnCanvasBehavior.Direction="Right"
                            Cursor="SizeWE"
                            Style="{StaticResource ResizeThumbStyle}" />
                    </Grid>

                    <DataTemplate.Triggers>
                        <!--  Выделение: синяя рамка + усиленная тень  -->
                        <DataTrigger Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=ListBoxItem}}" Value="True">
                            <Setter TargetName="MainBorder" Property="BorderBrush" Value="{StaticResource ControllerSelectedColorBrush}" />
                            <Setter TargetName="MainBorder" Property="BorderThickness" Value="2" />
                        </DataTrigger>
                    </DataTemplate.Triggers>
                </DataTemplate>
            </ListBox.ItemTemplate>

            <dxmvvm:Interaction.Behaviors>
                <dxmvvm:EventToCommand
                    Command="{Binding ItemsControlLoadedCommand}"
                    EventName="Loaded"
                    PassEventArgsToCommand="True" />
            </dxmvvm:Interaction.Behaviors>

        </ListBox>

    </DockPanel>
</local:BaseView>
