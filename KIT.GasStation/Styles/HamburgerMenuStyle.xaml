<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:customs="clr-namespace:KIT.GasStation.Customs"
    xmlns:dx="http://schemas.devexpress.com/winfx/2008/xaml/core"
    xmlns:dxwui="http://schemas.devexpress.com/winfx/2008/xaml/windowsui"
    xmlns:views="clr-namespace:KIT.GasStation.Views">

    <Style x:Key="TabItemStyle" TargetType="{x:Type dx:DXTabItem}">
        <Setter Property="HeaderTemplate">
            <Setter.Value>
                <DataTemplate>
                    <TextBlock
                        HorizontalAlignment="Left"
                        VerticalAlignment="Center"
                        Text="{Binding Title}" />
                </DataTemplate>
            </Setter.Value>
        </Setter>
        <Setter Property="Content" Value="{Binding}" />
        <Setter Property="AllowHide" Value="{Binding AllowHide}" />
        <Setter Property="IsSelected" Value="{Binding IsSelected}" />
        <Setter Property="CloseCommand" Value="{Binding Path=DataContext.CloseTabCommand, RelativeSource={RelativeSource AncestorType={x:Type customs:CustomHamburgerMenu}, Mode=FindAncestor}}" />
        <Setter Property="CloseCommandParameter" Value="{Binding}" />
    </Style>

    <Style x:Key="CustomHamburgerMenu" TargetType="{x:Type customs:CustomHamburgerMenu}">

        <Setter Property="ContentTemplate">
            <Setter.Value>
                <DataTemplate>
                    <dx:DXTabControl
                        ItemContainerStyle="{StaticResource TabItemStyle}"
                        ItemsSource="{Binding Path=DataContext.CurrentViewModels, RelativeSource={RelativeSource AncestorType={x:Type customs:CustomHamburgerMenu}, Mode=FindAncestor}}"
                        SelectedItem="{Binding Path=DataContext.CurrentViewModel, RelativeSource={RelativeSource AncestorType={x:Type customs:CustomHamburgerMenu}, Mode=FindAncestor}}">
                        <dx:DXTabControl.View>
                            <dx:TabControlMultiLineView HideButtonShowMode="InAllTabs" SingleTabItemHideMode="Hide" />
                        </dx:DXTabControl.View>
                    </dx:DXTabControl>
                </DataTemplate>
            </Setter.Value>
        </Setter>

    </Style>

    <Style x:Key="DefaultHamburgerSubMenu" TargetType="{x:Type dxwui:HamburgerSubMenu}">
        <Setter Property="MoreButtonVisibilityMode" Value="Hidden" />
        <Setter Property="ToolTip" Value="{Binding RelativeSource={RelativeSource Self}, Path=Content}" />
        <Setter Property="GlyphTemplate">
            <Setter.Value>
                <DataTemplate>
                    <Border>

                        <TextBlock Style="{StaticResource IconicTextBlock}" Text="{Binding RelativeSource={RelativeSource AncestorType={x:Type dxwui:HamburgerSubMenu}}, Path=Tag}" />

                    </Border>
                </DataTemplate>
            </Setter.Value>
        </Setter>

    </Style>

    <Style x:Key="DefaultHamburgerMenuNavigationButton" TargetType="{x:Type dxwui:HamburgerMenuNavigationButton}">
        <Setter Property="ToolTip" Value="{Binding RelativeSource={RelativeSource Self}, Path=Content}" />
        <Setter Property="Command" Value="{Binding ChangeCurrentViewModelCommand}" />
        <Setter Property="GlyphTemplate">
            <Setter.Value>
                <DataTemplate>
                    <Border>

                        <TextBlock Style="{StaticResource IconicTextBlock}" Text="{Binding RelativeSource={RelativeSource AncestorType={x:Type dxwui:HamburgerMenuNavigationButton}}, Path=Tag}" />

                    </Border>
                </DataTemplate>
            </Setter.Value>
        </Setter>

    </Style>

</ResourceDictionary>
