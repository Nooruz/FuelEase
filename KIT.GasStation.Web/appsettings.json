{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",

  "Licensing": {
    "ServerUrl": "https://license.kit-azs.ru",
    "PublicKey": "REPLACE_WITH_PUBLIC_KEY",
    "GracePeriodDays": 7,
    "OnlineCheckIntervalMinutes": 60,
    "MaxFailedOnlineChecks": 3,
    "ProductName": "KIT.GasStation",
    "ProtectedAssemblies": [
      "KIT.GasStation.Licensing.dll"
    ]
  },

  "Kestrel": {
    "Endpoints": {
      "Http": {
        "Url": "http://0.0.0.0:5005"
      }
      // Можно добавить HTTPS:
      // "Https": {
      //   "Url": "https://localhost:5443",
      //   "Certificate": {
      //     "Path": "certs/my.pfx",
      //     "Password": "secret"
      //   }
      // }
    }
  }

}
