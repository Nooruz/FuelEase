<UserControl
    x:Class="KIT.GasStation.Controls.NozzleControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:dxdo="http://schemas.devexpress.com/winfx/2008/xaml/docking"
    xmlns:dxe="http://schemas.devexpress.com/winfx/2008/xaml/editors"
    xmlns:dxlc="http://schemas.devexpress.com/winfx/2008/xaml/layoutcontrol"
    xmlns:helpers="clr-namespace:KIT.GasStation.Helpers"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Height="230"
    FontSize="24"
    mc:Ignorable="d">

    <Grid>

        <Grid Visibility="{Binding IsWorkingState, Converter={StaticResource BoolToVisibility}, FallbackValue=Hidden}">

            <ProgressBar
                BorderThickness="0"
                Foreground="{Binding Tank.Fuel.ColorBrush, Converter={StaticResource DrawingColorToBrushConverter}, FallbackValue=Green}"
                Maximum="{Binding CurrentFuelSale.Quantity, FallbackValue=100}"
                Minimum="0"
                Style="{StaticResource RoundedProgressBarVerticalBottomUp}"
                Value="{Binding CurrentFuelSale.ReceivedQuantity, FallbackValue=20}" />

            <Border
                Margin="5,0"
                Padding="2,0"
                VerticalAlignment="Center"
                Background="{StaticResource WhiteColorBrush}"
                BorderBrush="#AAA"
                BorderThickness="1">

                <TextBlock
                    FontSize="16"
                    Text="{Binding CurrentFuelSale.ReceivedPercentage, FallbackValue=100%}"
                    TextAlignment="Center" />

            </Border>

        </Grid>

        <Grid Visibility="{Binding IsWorkingState, Converter={StaticResource InverseBoolToVisibility}, FallbackValue=Visible}">

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition />
            </Grid.RowDefinitions>

            <Border Padding="2,0" Background="Transparent">

                <Grid>

                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition />
                    </Grid.RowDefinitions>

                    <Border
                        Margin="0,2,0,0"
                        Background="White"
                        BorderBrush="#AAA"
                        BorderThickness="1">
                        <TextBlock
                            HorizontalAlignment="Center"
                            Text="{Binding Tank.Fuel.Price, FallbackValue=168.59}"
                            TextAlignment="Center" />
                    </Border>

                    <Grid Grid.Row="1" Margin="5">

                        <Border
                            Width="40"
                            Height="40"
                            Background="{StaticResource WhiteColorBrush}"
                            BorderBrush="Black"
                            BorderThickness="2"
                            CornerRadius="40" />

                        <Border
                            Width="40"
                            Height="40"
                            Background="{Binding Tank.Fuel.ColorBrush, Converter={StaticResource DrawingColorToBrushConverter}}"
                            BorderBrush="Transparent"
                            BorderThickness="2"
                            CornerRadius="40" />

                        <Border Margin="0,5" Style="{StaticResource NozzleBorder}">
                            <!--  Используем Grid для центрирования содержимого  -->
                            <Grid>
                                <TextBlock
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    Text="{Binding Tube, FallbackValue=1}"
                                    TextAlignment="Center" />
                            </Grid>
                        </Border>
                    </Grid>

                </Grid>

            </Border>

            <Border
                Grid.Row="1"
                Padding="2,0"
                Background="{Binding Tank.Fuel.ColorBrush, Converter={StaticResource DrawingColorToBrushConverter}, FallbackValue=Red}">

                <Border
                    Padding="0,5"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Background="White"
                    BorderBrush="#AAA"
                    BorderThickness="1">

                    <TextBlock
                        Foreground="Black"
                        Text="{Binding Tank.Fuel.Name, FallbackValue=АИ-100}"
                        TextAlignment="Center">
                        <TextBlock.LayoutTransform>
                            <RotateTransform Angle="90" CenterX="0.5" CenterY="0.5" />
                        </TextBlock.LayoutTransform>
                    </TextBlock>

                </Border>

            </Border>

        </Grid>

    </Grid>

</UserControl>
