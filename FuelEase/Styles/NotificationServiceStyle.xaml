<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:dx="http://schemas.devexpress.com/winfx/2008/xaml/core"
                    xmlns:converters="clr-namespace:FuelEase.Converters">

    <converters:NotificationTypeToIconConverter x:Key="NotificationTypeToIconConverter"/>
    <converters:NotificationTypeToForegroundConverter x:Key="NotificationTypeToForegroundConverter"/>

    <Style x:Key="CustomNotificationStyle" TargetType="ContentControl">
        <Setter Property="Width" Value="360" />
        <Setter Property="Height" Value="100" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate>
                    <Border Width="{TemplateBinding Width}"
                            Height="{TemplateBinding Height}">
                        <Border.Background>
                            <SolidColorBrush Color="#26ABFF" Opacity=".6"/>
                        </Border.Background>
                        <Grid Margin="10 0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition />
                            </Grid.ColumnDefinitions>
                            <TextBlock Style="{StaticResource IconicTextBlock}"
                                       FontSize="24"
                                       TextAlignment="Center"
                                       Text="{Binding Type, Converter={StaticResource NotificationTypeToIconConverter}}"
                                       Foreground="{Binding Type, Converter={StaticResource NotificationTypeToForegroundConverter}}"/>
                            <StackPanel Margin="10"
                                        Grid.Column="1">
                                <TextBlock FontSize="14" 
                                           Foreground="White" 
                                           Text="{Binding Title}" 
                                           FontWeight="SemiBold" 
                                           Margin="0,0,0,5" />
                                <TextBlock FontSize="12"
                                           Foreground="Black"
                                           TextWrapping="Wrap"
                                           Text="{Binding Message}" />
                            </StackPanel>
                        </Grid>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>