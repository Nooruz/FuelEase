<local:BaseView xmlns:dxg="http://schemas.devexpress.com/winfx/2008/xaml/grid" 
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:dxe="http://schemas.devexpress.com/winfx/2008/xaml/editors"
    xmlns:dxlc="http://schemas.devexpress.com/winfx/2008/xaml/layoutcontrol"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:local="clr-namespace:KIT.GasStation.Views.Base"
                xmlns:dxb="http://schemas.devexpress.com/winfx/2008/xaml/bars"
    xmlns:dx="http://schemas.devexpress.com/winfx/2008/xaml/core"
    x:Class="KIT.GasStation.Views.Discounts.DiscountDetailView"
                Width="500">

    <UserControl.Resources>
        <Style TargetType="{x:Type dxg:GridColumn}" x:Key="NumericGridColumn">
            <Setter Property="EditSettings">
                <Setter.Value>
                    <dxe:ButtonEditSettings MaskUseAsDisplayFormat="True" 
                                            MaskType="Numeric" 
                                            Mask="n2"
                                            AllowDefaultButton="False">
                        <dxe:ButtonEditSettings.Buttons>
                            <dxe:ButtonInfo GlyphKind="Cancel" 
                                            ToolTip="Удалить"
                                            Command="{Binding DeleteDiscountTariffPlanCommand}"/>
                        </dxe:ButtonEditSettings.Buttons>
                    </dxe:ButtonEditSettings>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <dxlc:LayoutControl Orientation="Vertical">

        <dxlc:LayoutItem Label="Наименование">
            <dxe:TextEdit EditValue="{Binding SelectedDiscount.Name}"/>
        </dxlc:LayoutItem>

        <dxlc:LayoutGroup Header="Период действия скидки" 
                          View="GroupBox">

            <dxlc:LayoutItem Label="Дата начала">
                <dxe:DateEdit MaskUseAsDisplayFormat="True" 
                              EditValue="{Binding SelectedDiscount.StartDate}"
                              Mask="G">
                    <dxe:DateEdit.StyleSettings>
                        <dxe:DateEditNavigatorWithTimePickerStyleSettings/>
                    </dxe:DateEdit.StyleSettings>
                </dxe:DateEdit>
            </dxlc:LayoutItem>

            <dxlc:LayoutItem Label="Дата окончания">
                <dxe:DateEdit MaskUseAsDisplayFormat="True" 
                              EditValue="{Binding SelectedDiscount.EndDate}"
                              Mask="G">
                    <dxe:DateEdit.StyleSettings>
                        <dxe:DateEditNavigatorWithTimePickerStyleSettings/>
                    </dxe:DateEdit.StyleSettings>
                </dxe:DateEdit>
            </dxlc:LayoutItem>

        </dxlc:LayoutGroup>

        <dxlc:LayoutGroup Header="Тарифные планы" 
                          View="GroupBox"
                          Height="200">

            <dxg:GridControl ItemsSource="{Binding SelectedDiscount.DiscountTariffPlans}"
                             SelectedItem="{Binding SelectedDiscountTariffPlan}">
                <dxg:GridControl.View>
                    <dxg:TableView ShowGroupPanel="False"
                                   AutoWidth="True" 
                                   NewItemRowPosition="Top">
                        <dxg:TableView.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="Удалить"
                                          Command="{Binding DeleteDiscountTariffPlanCommand}"/>
                            </ContextMenu>
                        </dxg:TableView.ContextMenu>
                    </dxg:TableView>
                </dxg:GridControl.View>
                <dxg:GridColumn Header="Мин. значение"
                                FieldName="MinimumValue"
                                Style="{StaticResource DecimelGridColumn}"/>
                <dxg:GridColumn Header="Макс. значение"
                                FieldName="MaximumValue"
                                Style="{StaticResource DecimelGridColumn}"/>
                <dxg:GridColumn Header="Скидка"
                                FieldName="DiscountValue"
                                Style="{StaticResource DecimelGridColumn}"/>
                <dxg:GridColumn>
                    <dxg:GridColumn.EditSettings>
                        <dxe:ButtonEditSettings AllowDefaultButton="False">
                            <dxe:ButtonEditSettings.Buttons>
                                <dxe:ButtonInfo GlyphKind="Cancel" Content="Удалить"/>
                            </dxe:ButtonEditSettings.Buttons>
                        </dxe:ButtonEditSettings>
                    </dxg:GridColumn.EditSettings>
                </dxg:GridColumn>
            </dxg:GridControl>

        </dxlc:LayoutGroup>

        <dxlc:LayoutGroup Header="Выбор топлива" 
                          View="GroupBox"
                          Height="200">
            <dxg:GridControl ItemsSource="{Binding SelectedDiscount.DiscountFuels}"
                             SelectedItem="{Binding SelectedDiscountFuel}">
                <dxg:GridControl.View>
                    <dxg:TableView ShowGroupPanel="False"
                                   AutoWidth="True" 
                                   NewItemRowPosition="Top">
                        <dxg:TableView.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="Удалить"
                                          Command="{Binding DeleteFuelCommand}"/>
                            </ContextMenu>
                        </dxg:TableView.ContextMenu>
                    </dxg:TableView>
                </dxg:GridControl.View>
                <dxg:GridColumn Header="Наименование топлива"
                                FieldName="FuelId"
                                Style="{StaticResource DecimelGridColumn}">
                    <dxg:GridColumn.EditSettings>
                        <dxe:ComboBoxEditSettings ItemsSource="{Binding Fuels}"
                                                  DisplayMember="Name"
                                                  ValueMember="Id">
                            <dxe:ComboBoxEditSettings.Buttons>
                                <dxe:ButtonInfo GlyphKind="Cancel"
                                                Command="{Binding DeleteFuelCommand}"/>
                            </dxe:ComboBoxEditSettings.Buttons>
                        </dxe:ComboBoxEditSettings>
                    </dxg:GridColumn.EditSettings>
                </dxg:GridColumn>
            </dxg:GridControl>

        </dxlc:LayoutGroup>

        <dxb:ToolBarControl Style="{StaticResource BaseToolBarControl}">
            <dxb:BarButtonItem Style="{StaticResource SaveBarButton}"/>
            <dxb:BarButtonItem Style="{StaticResource CancelBarButton}"/>
        </dxb:ToolBarControl>

    </dxlc:LayoutControl>

</local:BaseView>
