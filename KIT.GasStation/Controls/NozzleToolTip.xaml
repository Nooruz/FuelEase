<UserControl
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:dxlc="http://schemas.devexpress.com/winfx/2008/xaml/layoutcontrol"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    x:Class="KIT.GasStation.Controls.NozzleToolTip"
    Width="250">
    <UserControl.Resources>

        <Style TargetType="TextBlock">
            <Setter Property="FontWeight" Value="Bold"/>
        </Style>
        
    </UserControl.Resources>

    <dxlc:LayoutControl Orientation="Vertical">

        <dxlc:LayoutGroup Header="LayoutGroup"
                          Orientation="Vertical"
                          Margin="0 0 0 10">
            
            <dxlc:LayoutItem Label="Состояние:">
                <TextBlock Text="asdads"/>
            </dxlc:LayoutItem>

            <dxlc:LayoutItem Label="Тип отпуска:">
                <TextBlock Text="литры"/>
            </dxlc:LayoutItem>

        </dxlc:LayoutGroup>

        <dxlc:LayoutGroup Orientation="Vertical">

            <dxlc:LayoutItem Label="Дата начала:">
                <TextBlock Text="asdads"/>
            </dxlc:LayoutItem>

            <dxlc:LayoutItem Label="Время начала:">
                <TextBlock Text="литры"/>
            </dxlc:LayoutItem>

            <dxlc:LayoutItem Label="Оператор:">
                <TextBlock Text="литры"/>
            </dxlc:LayoutItem>

            <dxlc:LayoutItem Label="Тип оплаты:">
                <TextBlock Text="литры"/>
            </dxlc:LayoutItem>

            <dxlc:LayoutItem Label="Топливо:">
                <TextBlock Text="литры"/>
            </dxlc:LayoutItem>

        </dxlc:LayoutGroup>

        <dxlc:LayoutGroup Orientation="Vertical"
                          View="GroupBox"
                          Header="Заявки">

            <dxlc:LayoutItem Label="Количество:">
                <TextBlock Text="asdads"/>
            </dxlc:LayoutItem>

            <dxlc:LayoutItem Label="Стоимость:">
                <TextBlock Text="литры"/>
            </dxlc:LayoutItem>

            <dxlc:LayoutItem Label="Скидка:">
                <TextBlock Text="литры"/>
            </dxlc:LayoutItem>

            <dxlc:LayoutItem Label="Итого:">
                <TextBlock Text="литры"/>
            </dxlc:LayoutItem>

        </dxlc:LayoutGroup>

        <dxlc:LayoutGroup Orientation="Vertical"
                          View="GroupBox"
                          Header="Отпуск">

            <dxlc:LayoutItem Label="Количество:">
                <TextBlock Text="asdads"/>
            </dxlc:LayoutItem>

            <dxlc:LayoutItem Label="Стоимость:">
                <TextBlock Text="литры"/>
            </dxlc:LayoutItem>

            <dxlc:LayoutItem Label="Скидка:">
                <TextBlock Text="литры"/>
            </dxlc:LayoutItem>

            <dxlc:LayoutItem Label="Итого:">
                <TextBlock Text="литры"/>
            </dxlc:LayoutItem>

        </dxlc:LayoutGroup>

        <dxlc:LayoutItem Label="Режим:">
            <TextBlock Text="литры"/>
        </dxlc:LayoutItem>

    </dxlc:LayoutControl>

</UserControl>
