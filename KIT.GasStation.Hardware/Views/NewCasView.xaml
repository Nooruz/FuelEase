<local:BaseView x:Class="KIT.GasStation.Hardware.Views.NewCasView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:dxb="http://schemas.devexpress.com/winfx/2008/xaml/bars"
             xmlns:dx="http://schemas.devexpress.com/winfx/2008/xaml/core"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:KIT.GasStation.Hardware.Views"
             xmlns:dxe="http://schemas.devexpress.com/winfx/2008/xaml/editors"
             xmlns:dxlc="http://schemas.devexpress.com/winfx/2008/xaml/layoutcontrol"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">

    <dxlc:LayoutControl Orientation="Vertical">

        <dxlc:LayoutItem Label="Адрес смарт карты">
            <dxe:TextEdit EditValue="{Binding SelectedCashRegister.Address}"/>
        </dxlc:LayoutItem>

        <dxlc:LayoutGroup Header="Реквизиты подключения" 
                      View="GroupBox"
                      Orientation="Vertical">

            <dxlc:LayoutItem Label="Регистрационный номер устройства">
                <dxe:TextEdit EditValue="{Binding SelectedCashRegister.RegistrationNumber}"/>
            </dxlc:LayoutItem>

            <dxlc:LayoutGroup HorizontalAlignment="Right"
                          VerticalAlignment="Top">

                <dxb:ToolBarControl Style="{StaticResource BaseToolBarControl}">
                    <dxb:BarButtonItem Content="Состояние ККМ"
                       Command="{Binding StateCommand}" 
                       Glyph="{dx:DXImage SvgImages/XAF/State_Validation_Valid.svg}"/>
                    <dxb:BarButtonItem Content="Открыть смену"
                       Command="{Binding OpenShiftCommand}" Glyph="{dx:DXImage SvgImages/XAF/State_Task_InProgress.svg}"/>
                    <dxb:BarButtonItem Content="Закрыть смену"
                       Command="{Binding CloseShiftCommand}" Glyph="{dx:DXImage SvgImages/Icon Builder/Actions_Clock.svg}"/>
                </dxb:ToolBarControl>

            </dxlc:LayoutGroup>

        </dxlc:LayoutGroup>

        <dxlc:LayoutGroup Header="Принтер" 
                  View="GroupBox"
                  Orientation="Vertical">

            <dxlc:LayoutItem Label="Принтер">
                <dxe:ComboBoxEdit ItemsSource="{Binding Printers}"
                                  EditValue="{Binding SelectedCashRegister.Settings.DefaultPrinterName, UpdateSourceTrigger=PropertyChanged}"/>
            </dxlc:LayoutItem>

        </dxlc:LayoutGroup>

        <dxlc:LayoutGroup >

            <dxb:ToolBarControl Style="{StaticResource BaseToolBarControl}">
                <dxb:BarButtonItem Content="Сохранить настройки"
                       Command="{Binding SaveCommand}" Glyph="{dx:DXImage SvgImages/XAF/Action_SaveScript.svg}"/>
            </dxb:ToolBarControl>

        </dxlc:LayoutGroup>

    </dxlc:LayoutControl>

</local:BaseView>
