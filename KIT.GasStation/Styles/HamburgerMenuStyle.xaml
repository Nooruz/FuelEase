<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:dx="http://schemas.devexpress.com/winfx/2008/xaml/core"
                    xmlns:dxwui="http://schemas.devexpress.com/winfx/2008/xaml/windowsui"
                    xmlns:customs="clr-namespace:KIT.GasStation.Customs"
                    xmlns:views="clr-namespace:KIT.GasStation.Views">

    <Style x:Key="TabItemStyle" TargetType="{x:Type dx:DXTabItem}">
        <Setter Property="HeaderTemplate">
            <Setter.Value>
                <DataTemplate>
                    <TextBlock Text="{Binding Title}"
                               HorizontalAlignment="Left"
                               VerticalAlignment="Center"/>
                </DataTemplate>
            </Setter.Value>
        </Setter>
        <Setter Property="Content" Value="{Binding}"/>
        <Setter Property="AllowHide" Value="{Binding AllowHide}"/>
        <Setter Property="IsSelected" Value="{Binding IsSelected}"/>
        <Setter Property="CloseCommand" Value="{Binding Path=DataContext.CloseTabCommand, RelativeSource={RelativeSource AncestorType={x:Type customs:CustomHamburgerMenu}, Mode=FindAncestor}}"/>
        <Setter Property="CloseCommandParameter" Value="{Binding}"/>
    </Style>

    <Style TargetType="{x:Type customs:CustomHamburgerMenu}" x:Key="CustomHamburgerMenu">

        <Setter Property="ContentTemplate">
            <Setter.Value>
                <DataTemplate>
                    <dx:DXTabControl ItemsSource="{Binding Path=DataContext.CurrentViewModels, RelativeSource={RelativeSource AncestorType={x:Type customs:CustomHamburgerMenu}, Mode=FindAncestor}}"
                                     ItemContainerStyle="{StaticResource TabItemStyle}"
                                     SelectedItem="{Binding Path=DataContext.CurrentViewModel, RelativeSource={RelativeSource AncestorType={x:Type customs:CustomHamburgerMenu}, Mode=FindAncestor}}">
                        <dx:DXTabControl.View>
                            <dx:TabControlMultiLineView HideButtonShowMode="InAllTabs"
                                                        SingleTabItemHideMode="Hide"/>
                        </dx:DXTabControl.View>
                    </dx:DXTabControl>
                </DataTemplate>
            </Setter.Value>
        </Setter>

    </Style>

    <Style TargetType="{x:Type dxwui:HamburgerSubMenu}" x:Key="DefaultHamburgerSubMenu">
        <Setter Property="MoreButtonVisibilityMode" Value="Hidden"/>
        <Setter Property="ToolTip" Value="{Binding RelativeSource={RelativeSource Self}, Path=Content}"/>
        <Setter Property="GlyphTemplate">
            <Setter.Value>
                <DataTemplate>
                    <Border>

                        <TextBlock Style="{StaticResource IconicTextBlock}" 
                                   Text="{Binding RelativeSource={RelativeSource AncestorType={x:Type dxwui:HamburgerSubMenu}}, Path=Tag}"/>

                    </Border>
                </DataTemplate>
            </Setter.Value>
        </Setter>

    </Style>

    <Style TargetType="{x:Type dxwui:HamburgerMenuNavigationButton}" x:Key="DefaultHamburgerMenuNavigationButton">
        <Setter Property="ToolTip" Value="{Binding RelativeSource={RelativeSource Self}, Path=Content}"/>
        <Setter Property="Command" Value="{Binding ChangeCurrentViewModelCommand}"/>
        <Setter Property="GlyphTemplate">
            <Setter.Value>
                <DataTemplate>
                    <Border>

                        <TextBlock Style="{StaticResource IconicTextBlock}" 
                               Text="{Binding RelativeSource={RelativeSource AncestorType={x:Type dxwui:HamburgerMenuNavigationButton}}, Path=Tag}"/>

                    </Border>
                </DataTemplate>
            </Setter.Value>
        </Setter>

    </Style>

</ResourceDictionary>