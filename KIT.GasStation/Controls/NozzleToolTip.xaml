<UserControl
    x:Class="KIT.GasStation.Controls.NozzleToolTip"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:dxlc="http://schemas.devexpress.com/winfx/2008/xaml/layoutcontrol"
    Width="250">
    <UserControl.Resources>

        <Style TargetType="TextBlock">
            <Setter Property="FontWeight" Value="Bold" />
        </Style>

    </UserControl.Resources>

    <dxlc:LayoutControl Orientation="Vertical">

        <dxlc:LayoutGroup
            Margin="0,0,0,10"
            Header="LayoutGroup"
            Orientation="Vertical">

            <dxlc:LayoutItem Label="Состояние">
                <TextBlock Text="asdads" />
            </dxlc:LayoutItem>

            <dxlc:LayoutItem Label="Тип отпуска">
                <TextBlock Text="литры" />
            </dxlc:LayoutItem>

        </dxlc:LayoutGroup>

        <dxlc:LayoutGroup Orientation="Vertical">

            <dxlc:LayoutItem Label="Дата начала">
                <TextBlock Text="asdads" />
            </dxlc:LayoutItem>

            <dxlc:LayoutItem Label="Время начала">
                <TextBlock Text="литры" />
            </dxlc:LayoutItem>

            <dxlc:LayoutItem Label="Оператор">
                <TextBlock Text="литры" />
            </dxlc:LayoutItem>

            <dxlc:LayoutItem Label="Тип оплаты">
                <TextBlock Text="литры" />
            </dxlc:LayoutItem>

            <dxlc:LayoutItem Label="Топливо">
                <TextBlock Text="литры" />
            </dxlc:LayoutItem>

        </dxlc:LayoutGroup>

        <dxlc:LayoutGroup
            Header="Заявки"
            Orientation="Vertical"
            View="GroupBox">

            <dxlc:LayoutItem Label="Количество">
                <TextBlock Text="asdads" />
            </dxlc:LayoutItem>

            <dxlc:LayoutItem Label="Стоимость">
                <TextBlock Text="литры" />
            </dxlc:LayoutItem>

            <dxlc:LayoutItem Label="Скидка">
                <TextBlock Text="литры" />
            </dxlc:LayoutItem>

            <dxlc:LayoutItem Label="Итого">
                <TextBlock Text="литры" />
            </dxlc:LayoutItem>

        </dxlc:LayoutGroup>

        <dxlc:LayoutGroup
            Header="Отпуск"
            Orientation="Vertical"
            View="GroupBox">

            <dxlc:LayoutItem Label="Количество">
                <TextBlock Text="asdads" />
            </dxlc:LayoutItem>

            <dxlc:LayoutItem Label="Стоимость">
                <TextBlock Text="литры" />
            </dxlc:LayoutItem>

            <dxlc:LayoutItem Label="Скидка">
                <TextBlock Text="литры" />
            </dxlc:LayoutItem>

            <dxlc:LayoutItem Label="Итого">
                <TextBlock Text="литры" />
            </dxlc:LayoutItem>

        </dxlc:LayoutGroup>

        <dxlc:LayoutItem Label="Режим">
            <TextBlock Text="литры" />
        </dxlc:LayoutItem>

    </dxlc:LayoutControl>

</UserControl>
