<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:dxmvvm="http://schemas.devexpress.com/winfx/2008/xaml/mvvm">



    <Style TargetType="{x:Type TreeViewItem}" x:Key="HardWareTreeViewItem">
        <Setter Property="ItemTemplate">
            <Setter.Value>
                <DataTemplate>
                    <TextBlock Text="{Binding Name}"/>
                </DataTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <ContextMenu x:Key="ControllerContextMenu">
        <MenuItem Header="Добавить ТРК"
                  Command="{Binding ControllerCreateCommand}"/>
    </ContextMenu>

    <ContextMenu x:Key="CashRegisterContextMenu">
        <MenuItem Header="Добавить ККМ"
                  Command="{Binding CashRegisterCreateCommand}"/>
    </ContextMenu>

    <ContextMenu x:Key="KITContextMenu">
        <MenuItem Header="Добавить"
              Command="{Binding KITCreateCommand}"/>
    </ContextMenu>

    <Style TargetType="{x:Type TreeView}" x:Key="HardWareTreeView">
        <Setter Property="ItemContainerStyle" Value="{StaticResource HardWareTreeViewItem}"/>
    </Style>

</ResourceDictionary>