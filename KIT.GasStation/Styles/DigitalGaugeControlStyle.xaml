<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:dxga="http://schemas.devexpress.com/winfx/2008/xaml/gauges">

    <Style x:Key="BaseDigitalScreenStyle" TargetType="{x:Type dxga:DigitalGaugeControl}">

        <Setter Property="SymbolCount" Value="8" />
        <Setter Property="TextDirection" Value="RightToLeft" />
        <Setter Property="Model">
            <Setter.Value>
                <dxga:DigitalCleanWhiteModel InnerPadding="0" />
            </Setter.Value>
        </Setter>

    </Style>

    <Style
        x:Key="DefaultDigitalScreenStyle"
        BasedOn="{StaticResource BaseDigitalScreenStyle}"
        TargetType="{x:Type dxga:DigitalGaugeControl}">

        <Setter Property="SymbolView">
            <Setter.Value>
                <dxga:SevenSegmentsView>
                    <dxga:SevenSegmentsView.Presentation>
                        <dxga:DefaultSevenSegmentsPresentation FillActive="#FF3131">
                            <dxga:DefaultSevenSegmentsPresentation.FillInactive>
                                <SolidColorBrush Opacity="0.1" Color="#FF3131" />
                            </dxga:DefaultSevenSegmentsPresentation.FillInactive>
                        </dxga:DefaultSevenSegmentsPresentation>
                    </dxga:SevenSegmentsView.Presentation>
                </dxga:SevenSegmentsView>
            </Setter.Value>
        </Setter>

    </Style>

</ResourceDictionary>
