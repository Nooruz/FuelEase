<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Style TargetType="{x:Type ProgressBar}" x:Key="ReservoirProgressBar">

        <!-- Зададим умолчания, чтобы не забыть -->
        <Setter Property="BorderBrush" Value="Black"/>
        <Setter Property="BorderThickness" Value="2"/>
        <Setter Property="Background" Value="White"/> <!-- «Пустая» часть -->
        <Setter Property="Foreground" Value="Red"/> <!-- «Заливка» (прогресс) -->

        <!-- Поворот на -90°, если нужно «вертикальное» отображение -->
        <Setter Property="LayoutTransform">
            <Setter.Value>
                <RotateTransform Angle="-90" CenterX="0.5" CenterY="0.5"/>
            </Setter.Value>
        </Setter>

        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type ProgressBar}">

                    <!-- Общий контейнер -->
                    <Grid x:Name="TemplateRoot" SnapsToDevicePixels="true">

                        <!-- 
                        1) "Основная" рамка, рисует чёрную обводку и «фон» (Background)
                           Фон — это то, что видно «под заливкой», когда прогресс < 100%. 
                           BorderThickness=2 => чёрная обводка в 2 пикселя. 
                    -->
                        <Border x:Name="Container"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="100"
                            Background="{TemplateBinding Background}"/>

                        <!-- 
                        2) Внутренний Grid с OpacityMask, чтобы заливка «вырезалась» 
                           по форме рамки Container (CornerRadius и т.д.). 
                    -->
                        <Grid>
                            <Grid.OpacityMask>
                                <VisualBrush Visual="{Binding ElementName=Container}"/>
                            </Grid.OpacityMask>

                            <!-- Трек (полоса), можно оставить Fill="Transparent" 
                             или убрать совсем, если не нужен -->
                            <Rectangle x:Name="PART_Track" Fill="Transparent" />

                            <!-- 
                            3) «Индикатор» прогресса. 
                               ClipToBounds="True" + HorizontalAlignment="Left" 
                               используется для «обрезания» по ширине (или высоте) 
                               по мере изменения Value. 
                        -->
                            <Grid x:Name="PART_Indicator" 
                                  ClipToBounds="True" 
                                  HorizontalAlignment="Left">

                                <Rectangle x:Name="Indicator" 
                                      Fill="{TemplateBinding Foreground}" />

                                <!-- 
                                Если используете анимацию «полосок», 
                                оставьте Rectangle "Animation" 
                                и соответствующую логику анимации.
                            -->
                                <Rectangle x:Name="Animation" 
                                       Fill="{TemplateBinding Foreground}">
                                    <Rectangle.RenderTransform>
                                        <TransformGroup>
                                            <ScaleTransform/>
                                            <SkewTransform/>
                                            <RotateTransform/>
                                            <TranslateTransform/>
                                        </TransformGroup>
                                    </Rectangle.RenderTransform>
                                </Rectangle>
                            </Grid>
                        </Grid>

                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>

