<local:BaseView x:Class="KIT.GasStation.Hardware.Views.KITView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:KIT.GasStation.Hardware.Views"
             xmlns:dxe="http://schemas.devexpress.com/winfx/2008/xaml/editors"
             xmlns:dxlc="http://schemas.devexpress.com/winfx/2008/xaml/layoutcontrol"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">

    <dxlc:LayoutControl Orientation="Vertical">

        <dxlc:LayoutItem Label="Адрес">
            <dxe:TextEdit EditValue="{Binding SelectedCashRegister.Address}"/>
        </dxlc:LayoutItem>

        <dxlc:LayoutGroup Header="Реквизиты подключения" 
                          View="GroupBox"
                          Orientation="Vertical">

            <dxlc:LayoutItem Label="Серийный номер ПО">
                <dxe:TextEdit EditValue="{Binding SelectedCashRegister.RegistrationNumber}"/>
            </dxlc:LayoutItem>

            <dxlc:LayoutItem Label="Номер САМ карты">
                <dxe:TextEdit EditValue="{Binding SelectedCashRegister.RegistrationNumber}"
                              IsReadOnly="True"/>
            </dxlc:LayoutItem>

            <dxlc:LayoutGroup HorizontalAlignment="Right"
                          VerticalAlignment="Top">

                <Button Content="Проверить"
                        Command="{Binding TestCommand}"/>

            </dxlc:LayoutGroup>

        </dxlc:LayoutGroup>

        <dxlc:LayoutGroup HorizontalAlignment="Right"
                          VerticalAlignment="Bottom">

            <Button Content="Сохранить настройки"
                    Command="{Binding SaveCommand}"/>

        </dxlc:LayoutGroup>

    </dxlc:LayoutControl>

</local:BaseView>
