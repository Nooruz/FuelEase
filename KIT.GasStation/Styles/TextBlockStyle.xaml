<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:converters="clr-namespace:KIT.GasStation.Converters">

    <converters:BackgroundToForegroundConverter x:Key="BackgroundToForegroundConverter"/>

    <Style TargetType="{x:Type TextBlock}">
        <Setter Property="Foreground">
            <Setter.Value>
                <Binding Path="Background"
                         RelativeSource="{RelativeSource AncestorType=Border}"
                         Converter="{StaticResource BackgroundToForegroundConverter}"/>
            </Setter.Value>
        </Setter>
    </Style>
    
    <Style TargetType="TextBlock" x:Key="IconicTextBlock">
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="FontFamily" Value="{StaticResource FontAwesomeBold}"/>
        <Setter Property="HorizontalAlignment" Value="Center"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>

    <Style TargetType="TextBlock" x:Key="ConnectionStatus" BasedOn="{StaticResource IconicTextBlock}">
        <Setter Property="Foreground" Value="Gray"/>
        <Setter Property="Text" Value="{StaticResource faQuestionCircle}"/>
        <Style.Triggers>
            <Trigger Property="Tag" Value="BeingVerified">
                <Setter Property="Text" Value="{StaticResource faSync}"/>
            </Trigger>
            <Trigger Property="Tag" Value="NotConnected">
                <Setter Property="Foreground" Value="Red"/>
                <Setter Property="Text" Value="{StaticResource faTimesCircle}"/>
            </Trigger>
            <Trigger Property="Tag" Value="Connected">
                <Setter Property="Foreground" Value="Green"/>
                <Setter Property="Text" Value="{StaticResource faCheckCircle}"/>
            </Trigger>
        </Style.Triggers>
    </Style>

</ResourceDictionary>