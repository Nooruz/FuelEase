<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:dx="http://schemas.devexpress.com/winfx/2008/xaml/core"
    xmlns:dxb="http://schemas.devexpress.com/winfx/2008/xaml/bars">

    <Style x:Key="BaseToolBarControl" TargetType="{x:Type dxb:ToolBarControl}">
        <Setter Property="AllowCustomizationMenu" Value="False" />
        <Setter Property="AllowQuickCustomization" Value="False" />
        <Setter Property="BarItemDisplayMode" Value="ContentAndGlyph" />
    </Style>

    <Style x:Key="BaseBarButtonItem" TargetType="{x:Type dxb:BarButtonItem}" />

    <Style
        x:Key="CreateBarButton"
        BasedOn="{StaticResource BaseBarButtonItem}"
        TargetType="{x:Type dxb:BarButtonItem}">
        <Setter Property="Glyph" Value="{dx:DXImage SvgImages/Icon Builder/Actions_AddCircled.svg}" />
        <Setter Property="Command" Value="{Binding CreateCommand}" />
        <Setter Property="Content" Value="Создать" />
    </Style>

    <Style
        x:Key="EditBarButton"
        BasedOn="{StaticResource BaseBarButtonItem}"
        TargetType="{x:Type dxb:BarButtonItem}">
        <Setter Property="Glyph" Value="{dx:DXImage SvgImages/Icon Builder/Actions_Edit.svg}" />
        <Setter Property="Command" Value="{Binding EditCommand}" />
        <Setter Property="Content" Value="Редактировать" />
    </Style>

    <Style
        x:Key="DeleteBarButton"
        BasedOn="{StaticResource BaseBarButtonItem}"
        TargetType="{x:Type dxb:BarButtonItem}">
        <Setter Property="Glyph" Value="{dx:DXImage SvgImages/Icon Builder/Actions_DeleteCircled.svg}" />
        <Setter Property="Command" Value="{Binding DeleteCommand}" />
        <Setter Property="Content" Value="Удалить" />
    </Style>

    <Style
        x:Key="SaveBarButton"
        BasedOn="{StaticResource BaseBarButtonItem}"
        TargetType="{x:Type dxb:BarButtonItem}">
        <Setter Property="Glyph" Value="{dx:DXImage SvgImages/XAF/Action_SaveScript.svg}" />
        <Setter Property="Command" Value="{Binding SaveCommand}" />
        <Setter Property="Content" Value="Сохранить" />
    </Style>

    <Style
        x:Key="CancelBarButton"
        BasedOn="{StaticResource BaseBarButtonItem}"
        TargetType="{x:Type dxb:BarButtonItem}">
        <Setter Property="Command" Value="{Binding CloseCommand}" />
        <Setter Property="Content" Value="Отменить" />
    </Style>

</ResourceDictionary>