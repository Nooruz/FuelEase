<UserControl
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:dxe="http://schemas.devexpress.com/winfx/2008/xaml/editors"
    xmlns:dxlc="http://schemas.devexpress.com/winfx/2008/xaml/layoutcontrol"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    x:Class="FuelEase.Views.Settings.IdentificationSettingsView"
               mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">

    <dxlc:LayoutControl Orientation="Vertical" >
        <dxlc:LayoutItem Label="Наименование АЗС">
            <dxe:TextEdit EditValue="{Binding NameGasStation, UpdateSourceTrigger=PropertyChanged}"/>
        </dxlc:LayoutItem>
        <dxlc:LayoutItem Label="Номер АЗС">
            <dxe:TextEdit EditValue="{Binding IdGasStation, UpdateSourceTrigger=PropertyChanged}"/>
        </dxlc:LayoutItem>
    </dxlc:LayoutControl>

</UserControl>
