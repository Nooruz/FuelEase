<base:BaseView
    x:Class="KIT.GasStation.Views.LoginView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:base="clr-namespace:KIT.GasStation.Views.Base"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:dxe="http://schemas.devexpress.com/winfx/2008/xaml/editors"
    xmlns:dxlc="http://schemas.devexpress.com/winfx/2008/xaml/layoutcontrol"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Width="350"
    HorizontalAlignment="Center"
    VerticalAlignment="Center"
    mc:Ignorable="d">

    <dxlc:LayoutControl
        Padding="20"
        ItemSpace="15"
        Orientation="Vertical">

        <dxlc:LayoutGroup Orientation="Vertical">

            <dxlc:LayoutItem Label="Пользователя">
                <dxe:ComboBoxEdit
                    AutoComplete="True"
                    DisplayMember="FullName"
                    IncrementalSearch="True"
                    ItemsSource="{Binding Users}"
                    SelectedItem="{Binding SelectedUser, UpdateSourceTrigger=PropertyChanged}"
                    ValueMember="FullName" />
            </dxlc:LayoutItem>

            <dxlc:LayoutItem Label="Пароль">
                <dxe:PasswordBoxEdit Text="{Binding SelectedUser.Password, UpdateSourceTrigger=PropertyChanged}" />
            </dxlc:LayoutItem>

            <dxlc:LayoutItem>
                <dxe:CheckEdit Content="Запомнить меня" EditValue="{Binding RememberMe}" />
            </dxlc:LayoutItem>

            <Button
                Height="30"
                VerticalAlignment="Top"
                Command="{Binding LoginCommand}"
                Content="Войти"
                IsDefault="True" />

        </dxlc:LayoutGroup>

    </dxlc:LayoutControl>

</base:BaseView>
