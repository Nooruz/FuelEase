<UserControl
    x:Class="KIT.GasStation.Views.GlobalReports.AnalyticsView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:dx="http://schemas.devexpress.com/winfx/2008/xaml/core"
    xmlns:dxc="http://schemas.devexpress.com/winfx/2008/xaml/charts"
    xmlns:dxe="http://schemas.devexpress.com/winfx/2008/xaml/editors"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="900"
    d:DesignWidth="1200"
    mc:Ignorable="d">

    <UserControl.Resources>

        <!--  KPI tile style  -->
        <Style x:Key="KpiTile" TargetType="Border">
            <Setter Property="Background" Value="#F5F7FA" />
            <Setter Property="BorderBrush" Value="#DDE3EC" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="Padding" Value="16,12" />
            <Setter Property="MinWidth" Value="160" />
            <Setter Property="Margin" Value="0,0,10,0" />
        </Style>

        <Style x:Key="KpiValue" TargetType="TextBlock">
            <Setter Property="FontSize" Value="22" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#1B3A6B" />
        </Style>

        <Style x:Key="KpiLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Foreground" Value="#7B8CAA" />
            <Setter Property="Margin" Value="0,4,0,0" />
        </Style>

    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!--  ── Toolbar ────────────────────────────────────────────────────  -->
        <Border
            Grid.Row="0"
            Padding="12,8"
            Background="#FFFFFF"
            BorderBrush="#DDE3EC"
            BorderThickness="0,0,0,1">
            <StackPanel VerticalAlignment="Center" Orientation="Horizontal">
                <TextBlock
                    Margin="0,0,8,0"
                    VerticalAlignment="Center"
                    Foreground="#555"
                    Text="Период:" />
                <dxe:ComboBoxEdit
                    Width="120"
                    DisplayMember="Display"
                    EditValue="{Binding SelectedPeriod, Mode=TwoWay}"
                    IsTextEditable="False"
                    ItemsSource="{Binding Periods}" />
                <dx:WaitIndicator
                    Width="24"
                    Height="24"
                    Margin="16,0,0,0"
                    VerticalAlignment="Center"
                    Content="Загрузка..."
                    DeferedVisibility="{Binding IsLoading}" />
            </StackPanel>
        </Border>

        <!--  ── Tabs ───────────────────────────────────────────────────────  -->
        <dx:DXTabControl Grid.Row="1">

            <!--  ════════════════════════════════ ПРОДАЖИ ═══════════════════  -->
            <dx:DXTabItem Header="Продажи">
                <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="12,12,12,16">

                        <!--  KPI row  -->
                        <WrapPanel Margin="0,0,0,14">
                            <Border Style="{StaticResource KpiTile}">
                                <StackPanel>
                                    <TextBlock Style="{StaticResource KpiValue}" Text="{Binding TotalRevenue, StringFormat={}{0:N0} сом}" />
                                    <TextBlock Style="{StaticResource KpiLabel}" Text="Выручка" />
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource KpiTile}">
                                <StackPanel>
                                    <TextBlock Style="{StaticResource KpiValue}" Text="{Binding TotalVolume, StringFormat={}{0:N1} л}" />
                                    <TextBlock Style="{StaticResource KpiLabel}" Text="Объём продаж" />
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource KpiTile}">
                                <StackPanel>
                                    <TextBlock Style="{StaticResource KpiValue}" Text="{Binding TotalTransactions}" />
                                    <TextBlock Style="{StaticResource KpiLabel}" Text="Транзакций" />
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource KpiTile}">
                                <StackPanel>
                                    <TextBlock Style="{StaticResource KpiValue}" Text="{Binding AvgRevenuePerShift, StringFormat={}{0:N0} сом}" />
                                    <TextBlock Style="{StaticResource KpiLabel}" Text="Ср. выручка за смену" />
                                </StackPanel>
                            </Border>
                        </WrapPanel>

                        <!--  Выручка по дням — area chart  -->
                        <!--  Series.DataSource привязывается к коллекции ViewModel  -->
                        <GroupBox Height="220" Margin="0,0,0,12" Header="Выручка по дням">
                            <dxc:ChartControl>
                                <dxc:ChartControl.Diagram>
                                    <dxc:XYDiagram2D>
                                        <dxc:XYDiagram2D.AxisX>
                                            <dxc:AxisX2D>
                                                <dxc:AxisX2D.DateTimeMeasureUnit>Day</dxc:AxisX2D.DateTimeMeasureUnit>
                                                <dxc:AxisX2D.Label>
                                                    <dxc:AxisLabel TextPattern="{}{A:dd.MM}" />
                                                </dxc:AxisX2D.Label>
                                            </dxc:AxisX2D>
                                        </dxc:XYDiagram2D.AxisX>
                                        <dxc:XYDiagram2D.Series>
                                            <dxc:AreaSeries2D
                                                ArgumentDataMember="Date"
                                                DataSource="{Binding RevenueByDay}"
                                                DisplayName="Выручка"
                                                LabelsVisibility="False"
                                                ValueDataMember="Value" />
                                        </dxc:XYDiagram2D.Series>
                                    </dxc:XYDiagram2D>
                                </dxc:ChartControl.Diagram>
                            </dxc:ChartControl>
                        </GroupBox>

                        <!--  Две диаграммы-пончика  -->
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="8" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <!--  Структура оплат  -->
                            <GroupBox Grid.Column="0" Height="240" Header="Структура оплат">
                                <dxc:ChartControl>
                                    <dxc:ChartControl.Diagram>
                                        <dxc:SimpleDiagram2D>
                                            <dxc:SimpleDiagram2D.Series>
                                                <dxc:NestedDonutSeries2D
                                                    ArgumentDataMember="Label"
                                                    DataSource="{Binding RevenueByPaymentType}"
                                                    DisplayName="Оплаты"
                                                    HoleRadiusPercent="55"
                                                    ValueDataMember="Value">
                                                    <dxc:NestedDonutSeries2D.Label>
                                                        <dxc:SeriesLabel />
                                                    </dxc:NestedDonutSeries2D.Label>
                                                </dxc:NestedDonutSeries2D>
                                            </dxc:SimpleDiagram2D.Series>
                                        </dxc:SimpleDiagram2D>
                                    </dxc:ChartControl.Diagram>
                                </dxc:ChartControl>
                            </GroupBox>

                            <!--  Объём по видам топлива  -->
                            <GroupBox Grid.Column="2" Height="240" Header="Объём по видам топлива">
                                <dxc:ChartControl>
                                    <dxc:ChartControl.Diagram>
                                        <dxc:SimpleDiagram2D>
                                            <dxc:SimpleDiagram2D.Series>
                                                <dxc:NestedDonutSeries2D
                                                    ArgumentDataMember="Label"
                                                    DataSource="{Binding VolumeByFuel}"
                                                    DisplayName="Топливо"
                                                    HoleRadiusPercent="55"
                                                    ValueDataMember="Value">
                                                    <dxc:NestedDonutSeries2D.Label>
                                                        <dxc:SeriesLabel />
                                                    </dxc:NestedDonutSeries2D.Label>
                                                </dxc:NestedDonutSeries2D>
                                            </dxc:SimpleDiagram2D.Series>
                                        </dxc:SimpleDiagram2D>
                                    </dxc:ChartControl.Diagram>
                                </dxc:ChartControl>
                            </GroupBox>

                        </Grid>

                        <!--  Продажи по часам суток — bar chart  -->
                        <GroupBox Height="220" Margin="0,0,0,12" Header="Продажи по часам суток">
                            <dxc:ChartControl>
                                <dxc:ChartControl.Diagram>
                                    <dxc:XYDiagram2D>
                                        <dxc:XYDiagram2D.Series>
                                            <dxc:BarSideBySideSeries2D
                                                ArgumentDataMember="HourLabel"
                                                DataSource="{Binding SalesByHour}"
                                                DisplayName="Выручка"
                                                LabelsVisibility="False"
                                                ValueDataMember="Revenue" />
                                        </dxc:XYDiagram2D.Series>
                                    </dxc:XYDiagram2D>
                                </dxc:ChartControl.Diagram>
                            </dxc:ChartControl>
                        </GroupBox>

                        <!--  Выручка по последним сменам — stacked bar
                              Каждая серия: одинаковый DataSource, разный ValueDataMember  -->
                        <GroupBox Height="240" Header="Выручка по последним сменам">
                            <dxc:ChartControl>
                                <dxc:ChartControl.Diagram>
                                    <dxc:XYDiagram2D>
                                        <dxc:XYDiagram2D.Series>
                                            <dxc:BarStackedSeries2D
                                                ArgumentDataMember="Label"
                                                DataSource="{Binding RevenueByShift}"
                                                DisplayName="Наличные"
                                                LabelsVisibility="False"
                                                ValueDataMember="Cash" />
                                            <dxc:BarStackedSeries2D
                                                ArgumentDataMember="Label"
                                                DataSource="{Binding RevenueByShift}"
                                                DisplayName="Безналичные"
                                                LabelsVisibility="False"
                                                ValueDataMember="Cashless" />
                                            <dxc:BarStackedSeries2D
                                                ArgumentDataMember="Label"
                                                DataSource="{Binding RevenueByShift}"
                                                DisplayName="Талон"
                                                LabelsVisibility="False"
                                                ValueDataMember="Ticket" />
                                            <dxc:BarStackedSeries2D
                                                ArgumentDataMember="Label"
                                                DataSource="{Binding RevenueByShift}"
                                                DisplayName="Ведомость"
                                                LabelsVisibility="False"
                                                ValueDataMember="Statement" />
                                        </dxc:XYDiagram2D.Series>
                                    </dxc:XYDiagram2D>
                                </dxc:ChartControl.Diagram>
                            </dxc:ChartControl>
                        </GroupBox>

                    </StackPanel>
                </ScrollViewer>
            </dx:DXTabItem>

            <!--  ══════════════════════════ ПРИЁМ ТОПЛИВА ══════════════════  -->
            <dx:DXTabItem Header="Приём топлива">
                <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="12,12,12,16">

                        <!--  KPI row  -->
                        <WrapPanel Margin="0,0,0,14">
                            <Border Style="{StaticResource KpiTile}">
                                <StackPanel>
                                    <TextBlock Style="{StaticResource KpiValue}" Text="{Binding TotalIntake, StringFormat={}{0:N1} л}" />
                                    <TextBlock Style="{StaticResource KpiLabel}" Text="Принято топлива" />
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource KpiTile}">
                                <StackPanel>
                                    <TextBlock Style="{StaticResource KpiValue}" Text="{Binding AvgIntakePerEvent, StringFormat={}{0:N1} л}" />
                                    <TextBlock Style="{StaticResource KpiLabel}" Text="Ср. объём поставки" />
                                </StackPanel>
                            </Border>
                        </WrapPanel>

                        <!--  Суммарный приём по дням — area chart  -->
                        <GroupBox Height="220" Margin="0,0,0,12" Header="Суммарный приём по дням">
                            <dxc:ChartControl>
                                <dxc:ChartControl.Diagram>
                                    <dxc:XYDiagram2D>
                                        <dxc:XYDiagram2D.AxisX>
                                            <dxc:AxisX2D>
                                                <dxc:AxisX2D.DateTimeMeasureUnit>Day</dxc:AxisX2D.DateTimeMeasureUnit>
                                                <dxc:AxisX2D.Label>
                                                    <dxc:AxisLabel TextPattern="{}{A:dd.MM}" />
                                                </dxc:AxisX2D.Label>
                                            </dxc:AxisX2D>
                                        </dxc:XYDiagram2D.AxisX>
                                        <dxc:XYDiagram2D.Series>
                                            <dxc:AreaSeries2D
                                                ArgumentDataMember="Date"
                                                DataSource="{Binding IntakeTotalByDay}"
                                                DisplayName="Приём"
                                                LabelsVisibility="False"
                                                ValueDataMember="Value" />
                                        </dxc:XYDiagram2D.Series>
                                    </dxc:XYDiagram2D>
                                </dxc:ChartControl.Diagram>
                            </dxc:ChartControl>
                        </GroupBox>

                        <!--  Donut + Multi-series в одном ряду  -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="8" />
                                <ColumnDefinition Width="2*" />
                            </Grid.ColumnDefinitions>

                            <!--  По видам топлива — donut  -->
                            <GroupBox Grid.Column="0" Height="280" Header="По видам топлива">
                                <dxc:ChartControl>
                                    <dxc:ChartControl.Diagram>
                                        <dxc:SimpleDiagram2D>
                                            <dxc:SimpleDiagram2D.Series>
                                                <dxc:NestedDonutSeries2D
                                                    ArgumentDataMember="Label"
                                                    DataSource="{Binding IntakeByFuel}"
                                                    DisplayName="Топливо"
                                                    HoleRadiusPercent="55"
                                                    ValueDataMember="Value">
                                                    <dxc:NestedDonutSeries2D.Label>
                                                        <dxc:SeriesLabel />
                                                    </dxc:NestedDonutSeries2D.Label>
                                                </dxc:NestedDonutSeries2D>
                                            </dxc:SimpleDiagram2D.Series>
                                        </dxc:SimpleDiagram2D>
                                    </dxc:ChartControl.Diagram>
                                </dxc:ChartControl>
                            </GroupBox>

                            <!--  Динамика по видам топлива — multi-series area
                                  ChartControl.DataSource + XYDiagram2D.SeriesDataMember + SeriesTemplate
                                  DevExpress автоматически создаёт отдельную серию на каждый уникальный FuelName  -->
                            <GroupBox Grid.Column="2" Height="280" Header="Динамика приёма по видам топлива">
                                <dxc:ChartControl DataSource="{Binding IntakeSeries}">
                                    <dxc:ChartControl.Diagram>
                                        <dxc:XYDiagram2D SeriesDataMember="FuelName">
                                            <dxc:XYDiagram2D.AxisX>
                                                <dxc:AxisX2D>
                                                    <dxc:AxisX2D.DateTimeMeasureUnit>Day</dxc:AxisX2D.DateTimeMeasureUnit>
                                                    <dxc:AxisX2D.Label>
                                                        <dxc:AxisLabel TextPattern="{}{A:dd.MM}" />
                                                    </dxc:AxisX2D.Label>
                                                </dxc:AxisX2D>
                                            </dxc:XYDiagram2D.AxisX>
                                            <dxc:XYDiagram2D.SeriesTemplate>
                                                <dxc:AreaSeries2D
                                                    ArgumentDataMember="Date"
                                                    LabelsVisibility="False"
                                                    ValueDataMember="Quantity" />
                                            </dxc:XYDiagram2D.SeriesTemplate>
                                        </dxc:XYDiagram2D>
                                    </dxc:ChartControl.Diagram>
                                </dxc:ChartControl>
                            </GroupBox>

                        </Grid>

                    </StackPanel>
                </ScrollViewer>
            </dx:DXTabItem>

        </dx:DXTabControl>

    </Grid>

</UserControl>
