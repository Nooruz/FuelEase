<local:BaseView
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:dxb="http://schemas.devexpress.com/winfx/2008/xaml/bars"
    xmlns:dxe="http://schemas.devexpress.com/winfx/2008/xaml/editors"
    xmlns:dxg="http://schemas.devexpress.com/winfx/2008/xaml/grid"
    xmlns:dxlc="http://schemas.devexpress.com/winfx/2008/xaml/layoutcontrol"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:dx="http://schemas.devexpress.com/winfx/2008/xaml/core"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:local="clr-namespace:KIT.GasStation.Views.Base"
    xmlns:dxmvvm="http://schemas.devexpress.com/winfx/2008/xaml/mvvm"
    x:Class="KIT.GasStation.Views.UncompletedSalesView"
                    mc:Ignorable="d" 
                    Height="600" 
                    Width="1000">

    <dx:LoadingDecorator>

        <dxlc:LayoutControl Orientation="Vertical">

            <dxg:GridControl ItemsSource="{Binding FuelSales}"
                             SelectionMode="Row"
                             SelectedItems="{Binding SelectedFuelSales}"
                             ShowLoadingPanel="{Binding ShowLoadingPanel}">
                <dxg:GridControl.View>
                    <dxg:TableView ShowTotalSummary="True"
                                   AllowEditing="False">
                        <dxg:TableView.RowCellMenuCustomizations>
                            <dxb:BarButtonItem Content="Завершить"
                                               Command="{Binding DataContext.CompleteFuelSaleCommand, RelativeSource={RelativeSource AncestorType={x:Type local:BaseView}, Mode=FindAncestor}}" 
                                               Glyph="{dx:DXImage SvgImages/Outlook Inspired/MarkComplete.svg}" 
                                               BarItemDisplayMode="ContentAndGlyph"/>
                            <dxb:BarButtonItem Content="Продолжить"
                                               Command="{Binding DataContext.ContinueFuelingCommand, RelativeSource={RelativeSource AncestorType={x:Type local:BaseView}, Mode=FindAncestor}}" 
                                               Glyph="{dx:DXImage SvgImages/XAF/Action_Debug_Start.svg}" 
                                               BarItemDisplayMode="ContentAndGlyph"/>
                        </dxg:TableView.RowCellMenuCustomizations>
                    </dxg:TableView>
                </dxg:GridControl.View>
                <dxg:GridColumn Header="Время"
                                FieldName="CreateDate">
                    <dxg:GridColumn.EditSettings>
                        <dxe:DateEditSettings MaskUseAsDisplayFormat="True" Mask="u"/>
                    </dxg:GridColumn.EditSettings>
                </dxg:GridColumn>
                <dxg:GridColumn Header="Топлива"
                                FieldName="Tank.Fuel.Name"/>
                <dxg:GridColumn Header="Цена"
                                FieldName="Tank.Fuel.Price"/>
                <dxg:GridColumn Header="Количество">
                    <dxg:GridColumn.Binding>
                        <MultiBinding Converter="{StaticResource ReceivedQuantityAndQuantityToStringConverter}">
                            <Binding Path="ReceivedQuantity"/>
                            <Binding Path="Quantity"/>
                        </MultiBinding>
                    </dxg:GridColumn.Binding>
                </dxg:GridColumn>
                <dxg:GridColumn Header="Сумма">
                    <dxg:GridColumn.Binding>
                        <MultiBinding Converter="{StaticResource ReceivedQuantityAndQuantityToStringConverter}">
                            <Binding Path="ReceivedSum"/>
                            <Binding Path="Sum"/>
                        </MultiBinding>
                    </dxg:GridColumn.Binding>
                </dxg:GridColumn>
                <dxg:GridColumn Header="Тип оплаты"
                                FieldName="PaymentType">
                    <dxg:GridColumn.EditSettings>
                        <dxe:ComboBoxEditSettings ItemsSource="{Binding PaymentTypes}"
                                                  ValueMember="Key"
                                                  DisplayMember="Value"/>
                    </dxg:GridColumn.EditSettings>
                </dxg:GridColumn>
                <dxg:GridColumn Header="Статус"
                                FieldName="FuelSaleStatus">
                    <dxg:GridColumn.EditSettings>
                        <dxe:ComboBoxEditSettings ItemsSource="{Binding FuelSaleStatuses}"
                                                  ValueMember="Key"
                                                  DisplayMember="Value"/>
                    </dxg:GridColumn.EditSettings>
                </dxg:GridColumn>
                <dxg:GridColumn Header="Чек"
                                FieldName="FiscalData.FiscalDocument"/>
            </dxg:GridControl>

            <dxlc:LayoutGroup VerticalAlignment="Top"
                              HorizontalAlignment="Right">

                <Button Content="Завершить"
                        Command="{Binding CompleteFuelSaleCommand}"/>
                <Button Content="Закрыть"
                        Command="{Binding CloseCommand}"/>

            </dxlc:LayoutGroup>

        </dxlc:LayoutControl>

    </dx:LoadingDecorator>

</local:BaseView>
