<local:BaseView
    x:Class="KIT.GasStation.Views.UncompletedSalesView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:dx="http://schemas.devexpress.com/winfx/2008/xaml/core"
    xmlns:dxb="http://schemas.devexpress.com/winfx/2008/xaml/bars"
    xmlns:dxe="http://schemas.devexpress.com/winfx/2008/xaml/editors"
    xmlns:dxg="http://schemas.devexpress.com/winfx/2008/xaml/grid"
    xmlns:dxlc="http://schemas.devexpress.com/winfx/2008/xaml/layoutcontrol"
    xmlns:dxmvvm="http://schemas.devexpress.com/winfx/2008/xaml/mvvm"
    xmlns:local="clr-namespace:KIT.GasStation.Views.Base"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Width="1200"
    Height="700"
    mc:Ignorable="d">

    <dx:LoadingDecorator>

        <dxlc:LayoutControl Orientation="Vertical">

            <dxlc:GroupBox Header="Продажи">
                <dxlc:LayoutGroup Orientation="Vertical">
                    <dxg:GridControl
                        ItemsSource="{Binding FuelSales}"
                        SelectedItem="{Binding SelectedFuelSale}"
                        SelectedItems="{Binding SelectedFuelSales}"
                        SelectionMode="Row"
                        ShowLoadingPanel="{Binding ShowFuelSaleLoadingPanel}">
                        <dxg:GridControl.View>
                            <dxg:TableView
                                AllowEditing="False"
                                ShowGroupPanel="False"
                                ShowTotalSummary="True">
                                <dxg:TableView.RowCellMenuCustomizations>
                                    <dxb:BarButtonItem
                                        BarItemDisplayMode="ContentAndGlyph"
                                        Command="{Binding DataContext.CompleteFuelSaleCommand, RelativeSource={RelativeSource AncestorType={x:Type local:BaseView}, Mode=FindAncestor}}"
                                        Content="Завершить"
                                        Glyph="{dx:DXImage SvgImages/Outlook Inspired/MarkComplete.svg}" />
                                    <dxb:BarButtonItem
                                        BarItemDisplayMode="ContentAndGlyph"
                                        Command="{Binding DataContext.ContinueFuelingCommand, RelativeSource={RelativeSource AncestorType={x:Type local:BaseView}, Mode=FindAncestor}}"
                                        Content="Продолжить"
                                        Glyph="{dx:DXImage SvgImages/XAF/Action_Debug_Start.svg}" />
                                    <dxb:BarButtonItem
                                        BarItemDisplayMode="ContentAndGlyph"
                                        Command="{Binding DataContext.PrintReceiptCommand, RelativeSource={RelativeSource AncestorType={x:Type local:BaseView}, Mode=FindAncestor}}"
                                        Content="{Binding DataContext.PrintReceiptTitle, RelativeSource={RelativeSource AncestorType={x:Type local:BaseView}, Mode=FindAncestor}}"
                                        Glyph="{dx:DXImage SvgImages/RichEdit/PrintLayoutView.svg}"
                                        IsVisible="{Binding DataContext.IsVisiblePrintReceipt, RelativeSource={RelativeSource AncestorType={x:Type local:BaseView}, Mode=FindAncestor}}" />
                                </dxg:TableView.RowCellMenuCustomizations>
                            </dxg:TableView>
                        </dxg:GridControl.View>
                        <dxg:GridColumn FieldName="CreateDate" Header="Время">
                            <dxg:GridColumn.EditSettings>
                                <dxe:DateEditSettings Mask="u" MaskUseAsDisplayFormat="True" />
                            </dxg:GridColumn.EditSettings>
                        </dxg:GridColumn>
                        <dxg:GridColumn FieldName="Tank.Fuel.Name" Header="Топлива" />
                        <dxg:GridColumn FieldName="Tank.Fuel.Price" Header="Цена" />
                        <dxg:GridColumn Header="Количество">
                            <dxg:GridColumn.Binding>
                                <MultiBinding Converter="{StaticResource ReceivedQuantityAndQuantityToStringConverter}">
                                    <Binding Path="ReceivedQuantity" />
                                    <Binding Path="Quantity" />
                                </MultiBinding>
                            </dxg:GridColumn.Binding>
                        </dxg:GridColumn>
                        <dxg:GridColumn Header="Сумма">
                            <dxg:GridColumn.Binding>
                                <MultiBinding Converter="{StaticResource ReceivedQuantityAndQuantityToStringConverter}">
                                    <Binding Path="ReceivedSum" />
                                    <Binding Path="Sum" />
                                </MultiBinding>
                            </dxg:GridColumn.Binding>
                        </dxg:GridColumn>
                        <dxg:GridColumn FieldName="PaymentType" Header="Тип оплаты">
                            <dxg:GridColumn.EditSettings>
                                <dxe:ComboBoxEditSettings
                                    DisplayMember="Value"
                                    ItemsSource="{Binding PaymentTypes}"
                                    ValueMember="Key" />
                            </dxg:GridColumn.EditSettings>
                        </dxg:GridColumn>
                        <dxg:GridColumn FieldName="FuelSaleStatus" Header="Статус">
                            <dxg:GridColumn.EditSettings>
                                <dxe:ComboBoxEditSettings
                                    DisplayMember="Value"
                                    ItemsSource="{Binding FuelSaleStatuses}"
                                    ValueMember="Key" />
                            </dxg:GridColumn.EditSettings>
                        </dxg:GridColumn>
                    </dxg:GridControl>
                    <dxlc:LayoutGroup HorizontalAlignment="Right" VerticalAlignment="Top">

                        <Button Command="{Binding CompleteFuelSaleCommand}" Content="Завершить" />

                    </dxlc:LayoutGroup>
                </dxlc:LayoutGroup>

            </dxlc:GroupBox>

            <dxlc:GroupBox Height="200" Header="Фискальные чеки (ККМ)">
                <dxlc:LayoutGroup Orientation="Vertical">
                    <dxg:GridControl
                        ItemsSource="{Binding SelectedFuelSale.FiscalDatas}"
                        SelectedItem="{Binding SelectedFiscalData}"
                        ShowLoadingPanel="{Binding ShowFiscalDataLoadingPanel}">
                        <dxg:GridControl.View>
                            <dxg:TableView AllowEditing="False" ShowGroupPanel="False" />
                        </dxg:GridControl.View>

                        <dxg:GridColumn FieldName="FiscalDocument" Header="ФД" />
                        <dxg:GridColumn FieldName="Quantity" Header="Кол-во" />
                        <dxg:GridColumn FieldName="Total" Header="Сумма" />
                        <dxg:GridColumn FieldName="OperationType" Header="Вид оплаты">
                            <dxg:GridColumn.EditSettings>
                                <dxe:ComboBoxEditSettings
                                    DisplayMember="Value"
                                    ItemsSource="{Binding OperationTypes}"
                                    ValueMember="Key" />
                            </dxg:GridColumn.EditSettings>
                        </dxg:GridColumn>
                    </dxg:GridControl>
                    <dxlc:LayoutGroup HorizontalAlignment="Right" VerticalAlignment="Top">

                        <Button Command="{Binding ReturnCommand}" Content="Возврат ККМ" />
                        <Button Command="{Binding CloseCommand}" Content="Закрыть" />

                    </dxlc:LayoutGroup>
                </dxlc:LayoutGroup>
            </dxlc:GroupBox>



        </dxlc:LayoutControl>

    </dx:LoadingDecorator>

</local:BaseView>
