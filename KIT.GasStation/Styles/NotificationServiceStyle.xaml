<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="clr-namespace:KIT.GasStation.Converters"
    xmlns:dx="http://schemas.devexpress.com/winfx/2008/xaml/core">

    <converters:NotificationTypeToIconConverter x:Key="NotificationTypeToIconConverter" />
    <converters:NotificationTypeToForegroundConverter x:Key="NotificationTypeToForegroundConverter" />

    <Style x:Key="CustomNotificationStyle" TargetType="ContentControl">
        <Setter Property="Width" Value="360" />
        <Setter Property="Height" Value="100" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate>
                    <Border Width="{TemplateBinding Width}" Height="{TemplateBinding Height}">
                        <Border.Background>
                            <SolidColorBrush Opacity=".6" Color="#26ABFF" />
                        </Border.Background>
                        <Grid Margin="10,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition />
                            </Grid.ColumnDefinitions>
                            <TextBlock
                                FontSize="24"
                                Foreground="{Binding Type, Converter={StaticResource NotificationTypeToForegroundConverter}}"
                                Style="{StaticResource IconicTextBlock}"
                                Text="{Binding Type, Converter={StaticResource NotificationTypeToIconConverter}}"
                                TextAlignment="Center" />
                            <StackPanel Grid.Column="1" Margin="10">
                                <TextBlock
                                    Margin="0,0,0,5"
                                    FontSize="14"
                                    FontWeight="SemiBold"
                                    Foreground="White"
                                    Text="{Binding Title}" />
                                <TextBlock
                                    FontSize="12"
                                    Foreground="Black"
                                    Text="{Binding Message}"
                                    TextWrapping="Wrap" />
                            </StackPanel>
                        </Grid>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
