<local:BaseView x:Class="KIT.GasStation.Hardware.Views.LanfengSettingsView"
                xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                xmlns:dxe="http://schemas.devexpress.com/winfx/2008/xaml/editors"
                xmlns:dxlc="http://schemas.devexpress.com/winfx/2008/xaml/layoutcontrol"
                xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                xmlns:local="clr-namespace:KIT.GasStation.Hardware.Views"
                Width="400">

    <dxlc:LayoutControl Orientation="Vertical">

        <dxlc:LayoutGroup VerticalAlignment="Top">

            <dxlc:LayoutItem Label="ТРК">
                <dxe:ComboBoxEdit ItemsSource="{Binding FuelNozzles}"
                                  DisplayMember="Name"
                                  SelectedItem="{Binding SelectedFuelNozzle}"/>
            </dxlc:LayoutItem>

            <Button Content="Считать"
                    HorizontalAlignment="Right"
                    Command="{Binding ReadDataCommand}"/>

        </dxlc:LayoutGroup>

        <dxlc:LayoutGroup Header="Управление клапанами" 
                          View="GroupBox">
            <dxlc:LayoutItem Label="Клапан в начале">
                <dxe:TextEdit EditValue="{Binding ValveBeginning}" 
                              MaskUseAsDisplayFormat="True"
                              MaskType="Numeric" 
                              Mask="n0"/>
            </dxlc:LayoutItem>
            <dxlc:LayoutItem Label="Клапан в конце">
                <dxe:TextEdit EditValue="{Binding ValveEnd}" 
                              MaskUseAsDisplayFormat="True"
                              MaskType="Numeric" 
                              Mask="n0"/>
            </dxlc:LayoutItem>

        </dxlc:LayoutGroup>

        <dxlc:LayoutGroup Header="Управление литровыми импульсами" 
                          View="GroupBox">
            <dxlc:LayoutItem Label="Время &quot;Нет ЛИ&quot;. с">
                <dxe:TextEdit EditValue="{Binding IsNoTime}" 
                              MaskUseAsDisplayFormat="True"
                              MaskType="Numeric" 
                              Mask="n0"/>
            </dxlc:LayoutItem>
            <dxlc:LayoutItem Label="Время останов. с">
                <dxe:TextEdit EditValue="{Binding StoppingTime}" 
                              MaskUseAsDisplayFormat="True"
                              MaskType="Numeric" 
                              Mask="n0"/>
            </dxlc:LayoutItem>

        </dxlc:LayoutGroup>

        <dxlc:LayoutGroup Header="Задержка включения ТРК после" 
                          View="GroupBox">
            <dxlc:LayoutItem Label="Снятия пистолета">
                <dxe:TextEdit EditValue="{Binding RemovingNozzle}" 
                              MaskUseAsDisplayFormat="True"
                              MaskType="Numeric" 
                              Mask="n0"/>
            </dxlc:LayoutItem>
            <dxlc:LayoutItem Label="Принуд. пуск">
                <dxe:TextEdit EditValue="{Binding ForcedStart}" 
                              MaskUseAsDisplayFormat="True"
                              MaskType="Numeric" 
                              Mask="n0"/>
            </dxlc:LayoutItem>

        </dxlc:LayoutGroup>

        <dxlc:LayoutGroup Header="Параметры" 
                          View="GroupBox">

            <dxlc:LayoutItem Label="Кнопка ПУСК/СТОП">
                <dxe:CheckEdit EditValue="{Binding StartStopButton}"/>
            </dxlc:LayoutItem>

        </dxlc:LayoutGroup>

        <dxlc:LayoutGroup VerticalAlignment="Top"
                          HorizontalAlignment="Right">
    
            <Button Content="Записать"/>
            <Button Content="Отмена"
                    Command="{Binding CloseCommand}"/>

        </dxlc:LayoutGroup>

    </dxlc:LayoutControl>

</local:BaseView>
