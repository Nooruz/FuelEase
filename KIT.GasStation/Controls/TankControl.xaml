<UserControl
    x:Class="KIT.GasStation.Controls.TankControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:helpers="clr-namespace:KIT.GasStation.Helpers"
    HorizontalAlignment="Stretch"
    VerticalAlignment="Stretch"
    FontSize="18">

    <Border
        Padding="5"
        BorderBrush="Black"
        BorderThickness="2"
        CornerRadius="5">

        <Grid>

            <Grid.RowDefinitions>

                <RowDefinition Height="25" />
                <RowDefinition />

            </Grid.RowDefinitions>

            <TextBlock
                FontSize="16"
                FontWeight="Bold"
                Text="{Binding Name, FallbackValue=Резервуар 1}"
                TextAlignment="Center" />

            <Grid Grid.Row="1">

                <Grid.ColumnDefinitions>

                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition />
                    <ColumnDefinition Width="Auto" />

                </Grid.ColumnDefinitions>

                <Border
                    Width="15"
                    BorderBrush="#808080"
                    BorderThickness="1,1,0,1"
                    CornerRadius="15 0 0 15">

                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Offset="0" Color="#BEBEBE" />
                            <GradientStop Offset=".6" Color="#D0D0D0" />
                            <GradientStop Offset="1" Color="#F7F7F7" />
                        </LinearGradientBrush>
                    </Border.Background>

                </Border>

                <Border
                    Grid.Column="1"
                    Padding="2"
                    BorderBrush="#808080"
                    BorderThickness="1">

                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                            <GradientStop Offset="0" Color="#BEBEBE" />
                            <GradientStop Offset="0.3" Color="#F7F7F7" />
                            <GradientStop Offset=".8" Color="#808080" />
                            <GradientStop Offset="1" Color="#909090" />
                        </LinearGradientBrush>
                    </Border.Background>

                    <Grid>

                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition />
                        </Grid.ColumnDefinitions>

                        <Grid>

                            <ProgressBar
                                Width="50"
                                BorderBrush="#808080"
                                Foreground="{Binding ColorBrush, Converter={StaticResource DrawingColorToBrushConverter}, FallbackValue=Red}"
                                Maximum="{Binding Size, FallbackValue=100}"
                                Minimum="0"
                                Style="{StaticResource RoundedProgressBarVerticalBottomUpCornered}"
                                Value="{Binding CurrentFuelQuantity, FallbackValue=93}" />

                            <Border
                                MinWidth="30"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Background="White"
                                BorderBrush="Silver"
                                BorderThickness="1"
                                CornerRadius="2">

                                <TextBlock
                                    Margin="4,1"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    FontSize="14"
                                    Text="{Binding FuelQuantityPercentage, StringFormat={}{0:F0}%, FallbackValue=45%}" />

                            </Border>

                        </Grid>

                        <Grid Grid.Column="1" Margin="2,0">

                            <Grid.RowDefinitions>
                                <RowDefinition />
                                <RowDefinition />
                                <RowDefinition />
                                <RowDefinition />
                            </Grid.RowDefinitions>

                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition />
                            </Grid.ColumnDefinitions>

                            <TextBlock Text="Топливо: " />
                            <TextBlock
                                Grid.Column="1"
                                FontWeight="Bold"
                                Text="{Binding Fuel, FallbackValue=АИ-100}" />

                            <TextBlock Grid.Row="1" Text="Объем: " />
                            <TextBlock
                                Grid.Row="1"
                                Grid.Column="1"
                                FontWeight="Bold"
                                Text="{Binding SizeDisplay, StringFormat=N2, FallbackValue=5 000.00}" />

                            <TextBlock Grid.Row="2" Text="Занято: " />
                            <TextBlock
                                Grid.Row="2"
                                Grid.Column="1"
                                FontWeight="Bold"
                                Text="{Binding CurrentQuantityDisplay, FallbackValue=3 000.00}" />

                            <TextBlock Grid.Row="3" Text="Своб.: " />
                            <TextBlock
                                Grid.Row="3"
                                Grid.Column="1"
                                FontWeight="Bold"
                                Text="{Binding FreeSpace, FallbackValue=2 000.00}" />

                        </Grid>

                    </Grid>

                </Border>

                <Border
                    Grid.Column="2"
                    Width="15"
                    BorderBrush="#808080"
                    BorderThickness="0,1,1,1"
                    CornerRadius="0 15 15 0">

                    <Border.Background>
                        <LinearGradientBrush StartPoint="1,0" EndPoint="0,0">
                            <GradientStop Offset="0" Color="#BEBEBE" />
                            <GradientStop Offset=".6" Color="#D0D0D0" />
                            <GradientStop Offset="1" Color="#F7F7F7" />
                        </LinearGradientBrush>
                    </Border.Background>

                </Border>

            </Grid>

        </Grid>

    </Border>

</UserControl>
