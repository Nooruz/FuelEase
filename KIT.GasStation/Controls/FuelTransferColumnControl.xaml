<UserControl
    x:Class="KIT.GasStation.Controls.FuelTransferColumnControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:control="clr-namespace:KIT.GasStation.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:dxb="http://schemas.devexpress.com/winfx/2008/xaml/bars"
    xmlns:dxdo="http://schemas.devexpress.com/winfx/2008/xaml/docking"
    xmlns:dxe="http://schemas.devexpress.com/winfx/2008/xaml/editors"
    xmlns:dxga="http://schemas.devexpress.com/winfx/2008/xaml/gauges"
    xmlns:dxlc="http://schemas.devexpress.com/winfx/2008/xaml/layoutcontrol"
    xmlns:dxmvvm="http://schemas.devexpress.com/winfx/2008/xaml/mvvm"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:view="clr-namespace:KIT.GasStation.Views.Base"
    Margin="3"
    d:DesignWidth="350"
    Background="{StaticResource WhiteColorBrush}"
    SnapsToDevicePixels="True"
    UseLayoutRounding="True"
    mc:Ignorable="d">

    <UserControl.Resources>
        <dxb:PopupMenu x:Key="Menu">
            <dxb:PopupMenu.Items>
                <dxb:BarButtonItem
                    Command="{Binding RelativeSource={RelativeSource AncestorType={x:Type UserControl}, Mode=FindAncestor}, Path=DataContext.StopFuelingCommand}"
                    Content="Остановить"
                    IsEnabled="{Binding Status, Converter={StaticResource NozzleStatusToEnableConverter}, ConverterParameter=StopFueling, UpdateSourceTrigger=PropertyChanged}" />
                <dxb:BarItemSeparator />
                <dxb:BarButtonItem
                    Command="{Binding RelativeSource={RelativeSource AncestorType={x:Type UserControl}, Mode=FindAncestor}, Path=DataContext.ResumeFuelingCommand}"
                    Content="Продолжить"
                    IsEnabled="{Binding Status, Converter={StaticResource NozzleStatusToEnableConverter}, ConverterParameter=ResumeFueling, UpdateSourceTrigger=PropertyChanged}" />
                <dxb:BarButtonItem
                    Command="{Binding RelativeSource={RelativeSource AncestorType={x:Type UserControl}, Mode=FindAncestor}, Path=DataContext.CompleteFuelingCommand}"
                    Content="Завершить"
                    IsEnabled="{Binding Status, Converter={StaticResource NozzleStatusToEnableConverter}, ConverterParameter=ResumeFueling, UpdateSourceTrigger=PropertyChanged}" />
                <dxb:BarButtonItem
                    Command="{Binding Path=DataContext.ReleaseFuelNozzleCommand, RelativeSource={RelativeSource AncestorType={x:Type UserControl}}}"
                    Content="Освободить"
                    IsEnabled="{Binding Status, Converter={StaticResource NozzleStatusToEnableConverter}, ConverterParameter=CompleteFueling, UpdateSourceTrigger=PropertyChanged}" />
                <dxb:BarItemSeparator />
                <dxb:BarButtonItem Content="Принудительный пуск" />
                <dxb:BarItemSeparator />
                <dxb:BarButtonItem
                    Command="{Binding Path=DataContext.PumpingCommand, RelativeSource={RelativeSource AncestorType={x:Type UserControl}}}"
                    Content="Перекачка"
                    IsEnabled="{Binding Status, Converter={StaticResource NozzleStatusToEnableConverter}, ConverterParameter=Pumping, UpdateSourceTrigger=PropertyChanged}" />
                <dxb:BarButtonItem
                    Command="{Binding Path=DataContext.StartFullFuelingCommand, RelativeSource={RelativeSource AncestorType={x:Type UserControl}}}"
                    Content="Отпуск до полного бака"
                    IsEnabled="{Binding Status, Converter={StaticResource NozzleStatusToEnableConverter}, ConverterParameter=Pumping, UpdateSourceTrigger=PropertyChanged}" />
                <dxb:BarItemSeparator />
                <dxb:BarButtonItem Command="{Binding ElementName=FuelTransferColumn, Path=DataContext.PrintLastReceiptCommand}" Content="Чек на последнюю продажу" />
                <dxb:BarItemSeparator />
                <dxb:BarSubItem Content="Состояние устройства">
                    <dxb:BarButtonItem
                        Command="{Binding Path=DataContext.GetMeterValueCommand, RelativeSource={RelativeSource AncestorType={x:Type UserControl}}}"
                        Content="Запросить счетчик"
                        IsEnabled="{Binding Status, Converter={StaticResource NozzleStatusToEnableConverter}, ConverterParameter=Pumping, UpdateSourceTrigger=PropertyChanged}" />

                    <!--  Блокировать ТРК  -->
                    <dxb:BarButtonItem Command="{Binding RelativeSource={RelativeSource AncestorType={x:Type UserControl}, Mode=FindAncestor}, Path=DataContext.NozzleBlockCommand}" Content="{Binding Status, Converter={StaticResource BarButtonItemContentConverter}, UpdateSourceTrigger=PropertyChanged, ConverterParameter=Block}" />

                    <!--  Включить автономный режим  -->
                    <dxb:BarButtonItem
                        Command="{Binding RelativeSource={RelativeSource AncestorType={x:Type UserControl}, Mode=FindAncestor}, Path=DataContext.ChangeControlModeCommand}"
                        Content="{Binding IsProgramControl, Converter={StaticResource BarButtonItemContentConverter}, UpdateSourceTrigger=PropertyChanged, ConverterParameter=IsProgramControl}"
                        IsEnabled="{Binding IsProgramControl, Converter={StaticResource ControlModeToIsEnabledConverter}, UpdateSourceTrigger=PropertyChanged, ConverterParameter=IsProgramControl}" />
                </dxb:BarSubItem>
            </dxb:PopupMenu.Items>
        </dxb:PopupMenu>
        <Style
            x:Key="MenuListBoxItem"
            BasedOn="{StaticResource NozzleListBoxItem}"
            TargetType="{x:Type ListBoxItem}">
            <Setter Property="dxb:BarManager.DXContextMenu" Value="{StaticResource Menu}" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        </Style>
    </UserControl.Resources>

    <Grid>

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <!--
                Height="Auto" вместо "*" — обязательно при размещении контрола
                внутри Viewbox: в unconstrained-пространстве * ряды схлопываются в 0.
                ListBox сам вычислит нужную высоту по содержимому (NozzleControl Height=230).
            -->
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border
            Grid.Row="0"
            Margin="0,0,0,3"
            Padding="4,2"
            Background="#F5F7FA"
            BorderBrush="#AAA"
            BorderThickness="1">
            <TextBlock
                FontSize="20"
                FontWeight="SemiBold"
                Foreground="#333333"
                Text="{Binding Caption, FallbackValue=- 5 -}"
                TextAlignment="Center" />
            <!--<StackPanel Orientation="Horizontal">
                <TextBox Width="100" Text="{Binding Width}" />
                <TextBox Width="100" Text="{Binding Height}" />
            </StackPanel>-->
        </Border>

        <Grid x:Name="grid" Grid.Row="1">

            <Grid.ColumnDefinitions>
                <ColumnDefinition />
                <ColumnDefinition Width="5" />
                <ColumnDefinition />
            </Grid.ColumnDefinitions>

            <Border
                Padding="5"
                Background="#FAFBFC"
                BorderBrush="#AAA"
                BorderThickness="1">

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <dxga:DigitalGaugeControl
                        Grid.Row="0"
                        Margin="0,0,0,2"
                        HorizontalAlignment="Stretch"
                        VerticalAlignment="Top"
                        Style="{StaticResource BaseDigitalScreenStyle}"
                        Text="{Binding SelectedNozzle.CurrentFuelSale.Sum, StringFormat=F2, FallbackValue=0.00}" />

                    <dxga:DigitalGaugeControl
                        Grid.Row="1"
                        Margin="0,0,0,2"
                        HorizontalAlignment="Stretch"
                        VerticalAlignment="Top"
                        Style="{StaticResource BaseDigitalScreenStyle}"
                        Text="{Binding SelectedNozzle.CurrentFuelSale.Quantity, StringFormat=F2, FallbackValue=0.00}" />

                    <dxga:DigitalGaugeControl
                        Grid.Row="2"
                        Margin="0,2,0,0"
                        HorizontalAlignment="Stretch"
                        VerticalAlignment="Top"
                        Style="{StaticResource BaseDigitalScreenStyle}"
                        SymbolCount="12"
                        Text="{Binding SelectedNozzle.SalesSum, StringFormat=F2, FallbackValue=0.00}" />

                </Grid>

            </Border>

            <Border
                Grid.Column="2"
                Padding="5"
                Background="#FAFBFC"
                BorderBrush="#AAA"
                BorderThickness="1">

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <dxga:DigitalGaugeControl
                        Grid.Row="0"
                        Margin="0,0,0,2"
                        HorizontalAlignment="Stretch"
                        VerticalAlignment="Top"
                        Style="{StaticResource DefaultDigitalScreenStyle}"
                        Text="{Binding SelectedNozzle.CurrentFuelSale.ReceivedSum, StringFormat=F2, FallbackValue=0.00, UpdateSourceTrigger=PropertyChanged}" />

                    <dxga:DigitalGaugeControl
                        Grid.Row="1"
                        Margin="0,0,0,2"
                        HorizontalAlignment="Stretch"
                        VerticalAlignment="Top"
                        Style="{StaticResource DefaultDigitalScreenStyle}"
                        Text="{Binding SelectedNozzle.CurrentFuelSale.ReceivedQuantity, StringFormat=F2, FallbackValue=0.00, UpdateSourceTrigger=PropertyChanged}" />

                    <dxga:DigitalGaugeControl
                        Grid.Row="2"
                        Margin="0,2,0,0"
                        HorizontalAlignment="Stretch"
                        VerticalAlignment="Top"
                        Style="{StaticResource DefaultDigitalScreenStyle}"
                        SymbolCount="12"
                        Text="{Binding SelectedNozzle.LastCounter, StringFormat=F2, FallbackValue=0.00}" />

                </Grid>

            </Border>

        </Grid>

        <Grid Grid.Row="2" Margin="0,5">

            <Grid.ColumnDefinitions>
                <ColumnDefinition />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <Border
                Background="#F5F7FA"
                BorderBrush="#AAA"
                BorderThickness="1">

                <TextBlock
                    VerticalAlignment="Center"
                    FontSize="20"
                    FontWeight="SemiBold"
                    Foreground="#333333"
                    Text="{Binding SelectedNozzle.Status, Converter={StaticResource EnumToStringConvertert}, FallbackValue=Ожидание}"
                    TextAlignment="Center" />

            </Border>

            <Border
                Grid.Column="1"
                Width="{Binding RelativeSource={RelativeSource Mode=Self}, Path=ActualHeight}"
                Margin="5,0,0,0"
                Background="#F5F7FA"
                BorderBrush="#D0D0D0"
                BorderThickness="1"
                CornerRadius="4">

                <TextBlock
                    VerticalAlignment="Center"
                    FontSize="20"
                    FontWeight="SemiBold"
                    Foreground="#333333"
                    Text="{Binding SelectedNozzle.Tube, FallbackValue=1}"
                    TextAlignment="Center" />

            </Border>

        </Grid>

        <ListBox
            x:Name="listBox"
            Grid.Row="3"
            Background="Transparent"
            IsEnabled="{Binding CanSelectedNozzle}"
            ItemContainerStyle="{StaticResource MenuListBoxItem}"
            ItemsSource="{Binding Nozzles}"
            SelectedItem="{Binding SelectedNozzle}"
            SelectionMode="Single"
            Style="{StaticResource NozzleListBox}">

            <d:ListBoxItem Content="Item 1" />
            <d:ListBoxItem Content="Item 2" />
            <d:ListBoxItem Content="Item 3" />
            <d:ListBoxItem Content="Item 3" />

            <dxmvvm:Interaction.Behaviors>
                <dxmvvm:EventToCommand Command="{Binding NozzleMouseDoubleClickCommand}" EventName="MouseDoubleClick" />
                <dxmvvm:EventToCommand
                    Command="{Binding NozzleMouseDownCommand}"
                    Event="PreviewMouseDown"
                    PassEventArgsToCommand="True" />
            </dxmvvm:Interaction.Behaviors>
        </ListBox>

    </Grid>

</UserControl>
