<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:dxe="http://schemas.devexpress.com/winfx/2008/xaml/editors"
    xmlns:dxprg="http://schemas.devexpress.com/winfx/2008/xaml/propertygrid">



    <DataTemplate x:Key="ReceiptPrintingModeTypeItemEditor">
        <dxe:ComboBoxEdit
            Name="PART_Editor"
            DisplayMember="Value"
            IsTextEditable="False"
            ItemsSource="{Binding DataContext.ReceiptPrintingModeTypes, RelativeSource={RelativeSource AncestorType=dxprg:PropertyGridControl}}"
            SelectedItem="{Binding DataContext.Settings.ReceiptPrintingModeTypeItem, RelativeSource={RelativeSource AncestorType=dxprg:PropertyGridControl}}"
            ValueMember="Key" />
    </DataTemplate>

</ResourceDictionary>
