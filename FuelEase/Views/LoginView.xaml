<base:BaseView x:Class="FuelEase.Views.LoginView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:dxe="http://schemas.devexpress.com/winfx/2008/xaml/editors"
             xmlns:dxlc="http://schemas.devexpress.com/winfx/2008/xaml/layoutcontrol"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:base="clr-namespace:FuelEase.Views.Base"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" 
             Width="350"
             VerticalAlignment="Center"
             HorizontalAlignment="Center">

    <dxlc:LayoutControl ItemSpace="15"
                        Padding="20"
                        Orientation="Vertical">

        <dxlc:LayoutGroup Orientation="Vertical">

            <dxlc:LayoutItem Label="Пользователя:">
                <dxe:ComboBoxEdit ItemsSource="{Binding Users}"
                                  DisplayMember="FullName"
                                  ValueMember="FullName"
                                  IncrementalSearch="True"
                                  AutoComplete="True"
                                  SelectedItem="{Binding SelectedUser, UpdateSourceTrigger=PropertyChanged}"/>
            </dxlc:LayoutItem>

            <dxlc:LayoutItem Label="Пароль:">
                <dxe:PasswordBoxEdit Text="{Binding SelectedUser.Password, UpdateSourceTrigger=PropertyChanged}"/>
            </dxlc:LayoutItem>

            <dxlc:LayoutItem>
                <dxe:CheckEdit Content="Запомнить меня"
                               EditValue="{Binding RememberMe}"/>
            </dxlc:LayoutItem>

            <Button Content="Войти"
                    Command="{Binding LoginCommand}"
                    IsDefault="True"
                    VerticalAlignment="Top"/>

        </dxlc:LayoutGroup>

    </dxlc:LayoutControl>

</base:BaseView>
