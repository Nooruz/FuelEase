<local:BaseView x:Class="KIT.GasStation.Hardware.Views.ColumnCountView"
                xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                xmlns:dxe="http://schemas.devexpress.com/winfx/2008/xaml/editors"
                xmlns:dxlc="http://schemas.devexpress.com/winfx/2008/xaml/layoutcontrol"
                xmlns:dxmvvm="http://schemas.devexpress.com/winfx/2008/xaml/mvvm"
                xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                xmlns:local="clr-namespace:KIT.GasStation.Hardware.Views"
                Width="300">

    <dxlc:LayoutControl Orientation="Vertical" >
        <dxlc:LayoutItem Label="Введите количество колонок"
                         LabelPosition="Top">
            <dxe:TextEdit EditValue="{Binding Count, UpdateSourceTrigger=PropertyChanged}">
                <dxmvvm:Interaction.Behaviors>
                    <dxmvvm:FocusBehavior />
                </dxmvvm:Interaction.Behaviors>
            </dxe:TextEdit>
        </dxlc:LayoutItem>
        <dxlc:LayoutGroup VerticalAlignment="Top">

            <Button Content="Ок" 
                    IsDefault="True"
                    Command="{Binding CreateCommand}"/>
            <Button Content="Отмена"
                    Command="{Binding CloseCommand}"/>

        </dxlc:LayoutGroup>
    </dxlc:LayoutControl>

</local:BaseView>
