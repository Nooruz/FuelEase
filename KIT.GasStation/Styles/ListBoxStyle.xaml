<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:controls="clr-namespace:KIT.GasStation.Controls"
                    xmlns:converters="clr-namespace:KIT.GasStation.Converters"
                    xmlns:dxdo="http://schemas.devexpress.com/winfx/2008/xaml/docking"
                    xmlns:dxb="http://schemas.devexpress.com/winfx/2008/xaml/bars">

    <converters:NozzleMarginConverter x:Key="NozzleMarginConverter"/>
    <converters:NozzleStatusToBackgroundConverter x:Key="NozzleStatusToBackgroundConverter"/>

    <Style TargetType="{x:Type ListBox}" x:Key="NozzleListBox">

        <Setter Property="ItemsPanel">
            <Setter.Value>
                <ItemsPanelTemplate>
                    <!--<StackPanel Orientation="Horizontal"/>-->
                    <!--<controls:StretchyWrapPanel VerticalAlignment="Stretch"
                                                    Background="Green"/>-->
                    <!--<UniformGrid Columns="{Binding RelativeSource={RelativeSource AncestorType=ListBox},
                                 Path=Items.Count,
                                 Converter={StaticResource NozzleColumnsConverter}}"/>-->
                    <controls:NozzleUniformGrid MaxColumns="4"/>
                </ItemsPanelTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="ListBoxItem" x:Key="NozzleListBoxItem">
        <Setter Property="VerticalAlignment" Value="Stretch"/>
        <Setter Property="HorizontalAlignment" Value="Stretch"/>
        <Setter Property="BorderBrush" Value="{StaticResource TankForegroundColorBrush}"/>
        <Setter Property="Margin">
            <Setter.Value>
                <MultiBinding Converter="{StaticResource NozzleMarginConverter}">
                    <Binding RelativeSource="{RelativeSource Self}"/>
                    <Binding RelativeSource="{RelativeSource AncestorType={x:Type ListBox}}" Path="Items.Count"/>
                </MultiBinding>
            </Setter.Value>
        </Setter>
        <Setter Property="Background">
            <Setter.Value>
                <MultiBinding Converter="{StaticResource NozzleStatusToBackgroundConverter}">
                    <Binding Path="Status"/>
                    <Binding Path="IsProgramControl"/>
                </MultiBinding>
            </Setter.Value>
        </Setter>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type ListBoxItem}">
                    <Border Name="Border"
                            BorderThickness="2"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            SnapsToDevicePixels="True"
                            Background="{TemplateBinding Background}">
                        <controls:NozzleControl VerticalAlignment="Stretch"
                                                HorizontalAlignment="Stretch"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="BorderBrush" Value="{StaticResource TankMinimumForegroundColorBrush}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        

    </Style>

</ResourceDictionary>