<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:baseView="clr-namespace:KIT.GasStation.Views.Base"
                    xmlns:dxmvvm="http://schemas.devexpress.com/winfx/2008/xaml/mvvm"
                    xmlns:local="clr-namespace:KIT.GasStation.Views.Base">



    <Style TargetType="{x:Type TreeViewItem}" x:Key="HardWareTreeViewItem">
        <Setter Property="ItemTemplate">
            <Setter.Value>
                <DataTemplate>
                    <TextBlock Text="{Binding Name}"/>
                </DataTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <ContextMenu x:Key="FuelTransferColumnContextMenu">
        <MenuItem Header="Добавить ТРК"
                  Command="{Binding FuelTransferColumnCreateCommand}"/>
    </ContextMenu>

    <ContextMenu x:Key="CashRegisterContextMenu">
        <MenuItem Header="Добавить ККМ"
              Command="{Binding CashRegisterCreateCommand}"/>
    </ContextMenu>

    <Style TargetType="{x:Type TreeView}" x:Key="HardWareTreeView">
        <Setter Property="ItemContainerStyle" Value="{StaticResource HardWareTreeViewItem}"/>
    </Style>

</ResourceDictionary>