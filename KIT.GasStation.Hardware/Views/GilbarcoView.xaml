<local:BaseView x:Class="KIT.GasStation.Hardware.Views.GilbarcoView"
                xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                xmlns:dx="http://schemas.devexpress.com/winfx/2008/xaml/core"
                xmlns:dxe="http://schemas.devexpress.com/winfx/2008/xaml/editors"
                xmlns:dxg="http://schemas.devexpress.com/winfx/2008/xaml/grid"
                xmlns:dxlc="http://schemas.devexpress.com/winfx/2008/xaml/layoutcontrol"
                xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                xmlns:local="clr-namespace:KIT.GasStation.Hardware.Views"
                mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="1200">

    <dx:LoadingDecorator FadeInDuration="0" FadeOutDuration="0:0:0:1">

        <dxlc:LayoutControl Orientation="Vertical">

            <dxlc:LayoutGroup VerticalAlignment="Top">

                <dxlc:LayoutGroup Orientation="Vertical">

                    <dxlc:LayoutItem Label="Порт">
                        <dxe:ComboBoxEdit ItemsSource="{Binding AvailablePorts}"
                                          IsTextEditable="False"
                                          EditValue="{Binding SelectedController.ComPort}"/>
                    </dxlc:LayoutItem>

                    <dxlc:LayoutItem Label="Скорость">
                        <dxe:ComboBoxEdit ItemsSource="{Binding BaudRates}"
                                          IsTextEditable="False"
                                          EditValue="{Binding SelectedController.BaudRate}"/>
                    </dxlc:LayoutItem>

                    <dxlc:LayoutItem Label="Контроль">
                        <dxe:ComboBoxEdit ItemsSource="{Binding Parities}"
                                          IsTextEditable="False"
                                          EditValue="{Binding SelectedController.Settings.Parity}"/>
                    </dxlc:LayoutItem>

                    <dxlc:LayoutItem Label="Кол-во пистолетов на стороне">
                        <dxe:ComboBoxEdit ItemsSource="{Binding ColumnQuantities}"
                                          IsTextEditable="False"
                                          DisplayMember="Value"
                                          ValueMember="Key"
                                          EditValue="{Binding SelectedColumnQuantity}"/>
                    </dxlc:LayoutItem>

                </dxlc:LayoutGroup>

                <dxlc:LayoutGroup Orientation="Vertical">

                    <dxlc:LayoutItem Label="Подавление эхо">
                        <dxe:CheckEdit EditValue="{Binding SelectedController.Settings.EchoSuppression}"/>
                    </dxlc:LayoutItem>

                    <!--<dxlc:LayoutItem Label="Заявка на целые литры">
                        <dxe:CheckEdit/>
                    </dxlc:LayoutItem>-->

                </dxlc:LayoutGroup>

                <dxlc:LayoutGroup View="GroupBox"
                                  Orientation="Vertical"
                                  Header="Лог">

                    <dxlc:LayoutItem Label="Пакетный">
                        <dxe:CheckEdit/>
                    </dxlc:LayoutItem>

                    <dxlc:LayoutItem Label="Низкоуровневый">
                        <dxe:CheckEdit/>
                    </dxlc:LayoutItem>

                </dxlc:LayoutGroup>

            </dxlc:LayoutGroup>

            <dxg:GridControl ItemsSource="{Binding SelectedController.Columns}"
                             SelectedItem="{Binding SelectedColumn}">
                <dxg:GridControl.View>
                    <dxg:TableView ShowGroupPanel="False">
                        <dxg:TableView.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="Добавить"
                                          Command="{Binding AddColumnCommand}"/>
                                <MenuItem Header="Удалить"
                                          Command="{Binding DeleteColumnCommand}"/>
                            </ContextMenu>
                        </dxg:TableView.ContextMenu>
                    </dxg:TableView>
                </dxg:GridControl.View>
                <dxg:GridColumn Header="Связь"
                                FieldName="ConnectionStatus">
                    <dxg:GridColumn.CellTemplate>
                        <DataTemplate>
                            <dxlc:LayoutControl Padding="0 0 5 0" ItemSpace="5">
                                <Button Content="Проверка"
                                        Command="{Binding DataContext.CheckStatusCommand, RelativeSource={RelativeSource AncestorType={x:Type local:BaseView}, Mode=FindAncestor}}" />
                                <TextBlock HorizontalAlignment="Center"
                                           Text="{Binding RowData.Row.ConnectionStatus, Converter={StaticResource ColumnConnectionStatusConverter}}"
                                           Foreground="{Binding RowData.Row.ConnectionStatus, Converter={StaticResource ColumnConnectionStatusForegroundConverter}}"
                                           VerticalAlignment="Center"
                                           Style="{StaticResource ConnectionStatus}"/>
                            </dxlc:LayoutControl>
                        </DataTemplate>
                    </dxg:GridColumn.CellTemplate>
                </dxg:GridColumn>
                <dxg:GridColumn Header="Адрес"
                                FieldName="Address">
                    <dxg:GridColumn.EditSettings>
                        <dxe:SpinEditSettings AllowSpin="False"
                                              MinValue="0"
                                              MaxValue="255"/>
                    </dxg:GridColumn.EditSettings>
                </dxg:GridColumn>
                <dxg:GridColumn Header="Пистолет"
                                FieldName="Nozzle">
                    <dxg:GridColumn.EditSettings>
                        <dxe:SpinEditSettings MinValue="1"
                                      MaxValue="4"
                                      AllowSpin="False"/>
                    </dxg:GridColumn.EditSettings>
                </dxg:GridColumn>
                <dxg:GridColumn Header="Имя" FieldName="Name"/>
                <dxg:GridColumn Header="Блокирована" FieldName="Settings.IsDisabled"/>
                <dxg:GridColumn Header="Кол-во пистолетов на стороне" FieldName="Settings.ColumnQuantity">
                    <dxg:GridColumn.EditSettings>
                        <dxe:ComboBoxEditSettings ItemsSource="{Binding ColumnQuantities}"
                                                  DisplayMember="Value"
                                                  ValueMember="Key"/>
                    </dxg:GridColumn.EditSettings>
                </dxg:GridColumn>
                <dxg:GridColumn Header="Цена, после запятой" FieldName="Settings.PriceDecimalPoint">
                    <dxg:GridColumn.EditSettings>
                        <dxe:ComboBoxEditSettings ItemsSource="{Binding PriceDecimalPoints}"
                                                  DisplayMember="Value"
                                                  ValueMember="Key"/>
                    </dxg:GridColumn.EditSettings>
                </dxg:GridColumn>
            </dxg:GridControl>

            <Button HorizontalAlignment="Right"
                    VerticalAlignment="Bottom"
                    Content="Сохранить настройки"
                    Command="{Binding SaveCommand}"/>

        </dxlc:LayoutControl>

    </dx:LoadingDecorator>

</local:BaseView>
