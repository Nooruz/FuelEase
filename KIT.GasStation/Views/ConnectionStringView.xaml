<local:BaseView
    x:Class="KIT.GasStation.Views.ConnectionStringView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="clr-namespace:KIT.GasStation.Converters"
    xmlns:dxe="http://schemas.devexpress.com/winfx/2008/xaml/editors"
    xmlns:dxlc="http://schemas.devexpress.com/winfx/2008/xaml/layoutcontrol"
    xmlns:dxmvvm="http://schemas.devexpress.com/winfx/2008/xaml/mvvm"
    xmlns:local="clr-namespace:KIT.GasStation.Views.Base"
    Width="400">

    <local:BaseView.Resources>
        <!--  Регистрируем конвертер  -->
        <converters:AuthenticationConverter x:Key="AuthenticationConverter" />
    </local:BaseView.Resources>

    <dxlc:LayoutControl Orientation="Vertical">

        <dxlc:LayoutItem Label="Имя сервера">
            <dxe:TextEdit EditValue="{Binding ServerName}" />
        </dxlc:LayoutItem>

        <dxlc:LayoutItem Label="Проверка подлинности">
            <dxe:ComboBoxEdit
                DisplayMember="Value"
                EditValue="{Binding AuthenticationType}"
                ItemsSource="{Binding AvailableAuthentications}"
                ShowError="False"
                ShowErrorToolTip="False"
                ValueMember="Key" />
        </dxlc:LayoutItem>

        <dxlc:LayoutGroup
            Header="Параметры подключения"
            Orientation="Vertical"
            View="GroupBox">

            <dxlc:LayoutItem Label="Имя пользователя">
                <dxe:TextEdit EditValue="{Binding UserName}" />
            </dxlc:LayoutItem>

            <dxlc:LayoutItem Label="Пароль">
                <dxe:PasswordBoxEdit EditValue="{Binding Password}" />
            </dxlc:LayoutItem>

        </dxlc:LayoutGroup>

        <dxlc:LayoutGroup
            Header="Свойства соединения"
            Orientation="Vertical"
            View="GroupBox">

            <dxlc:LayoutItem>
                <dxe:CheckEdit
                    HorizontalAlignment="Left"
                    Content="Шифровать соединение"
                    EditValue="{Binding Encryp}" />
            </dxlc:LayoutItem>

            <dxlc:LayoutItem>
                <dxe:CheckEdit
                    HorizontalAlignment="Left"
                    Content="Доверять сертификату сервера"
                    EditValue="{Binding TrustServerCertificate}" />
            </dxlc:LayoutItem>

        </dxlc:LayoutGroup>

        <dxlc:LayoutItem Label="База данных">
            <dxe:ComboBoxEdit
                EditValue="{Binding SelectedDataBase}"
                ItemsSource="{Binding AvailableDataBases}"
                ShowError="False"
                ShowErrorToolTip="False">
                <dxmvvm:Interaction.Behaviors>
                    <dxmvvm:EventToCommand
                        Command="{Binding AvailableDataBasesPopupOpeningCommand}"
                        EventName="PopupOpening"
                        PassEventArgsToCommand="True" />
                </dxmvvm:Interaction.Behaviors>
            </dxe:ComboBoxEdit>
        </dxlc:LayoutItem>

        <Separator />

        <dxlc:LayoutGroup HorizontalAlignment="Right">

            <Button
                Width="90"
                Command="{Binding CheckConnectionCommand}"
                Content="Проверить" />
            <Button
                Width="90"
                Command="{Binding SaveCommand}"
                Content="Сохранить" />
            <Button Width="90" Content="Закрыть" />

        </dxlc:LayoutGroup>

    </dxlc:LayoutControl>

</local:BaseView>
