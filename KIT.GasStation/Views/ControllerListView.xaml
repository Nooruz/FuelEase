<local:BaseView
    x:Class="KIT.GasStation.Views.ControllerListView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:Editors="clr-namespace:DevExpress.Xpf.Editors;assembly=DevExpress.Xpf.Core.v21.2"
    xmlns:behaviors="clr-namespace:KIT.GasStation.Behavior"
    xmlns:customControls="clr-namespace:KIT.GasStation.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:dx="http://schemas.devexpress.com/winfx/2008/xaml/core"
    xmlns:dxdo="http://schemas.devexpress.com/winfx/2008/xaml/docking"
    xmlns:dxmvvm="http://schemas.devexpress.com/winfx/2008/xaml/mvvm"
    xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
    xmlns:local="clr-namespace:KIT.GasStation.Views.Base"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:viewModels="clr-namespace:KIT.GasStation.ViewModels"
    d:DesignHeight="500"
    d:DesignWidth="600"
    mc:Ignorable="d">

    <local:BaseView.Resources>
        <Style x:Key="ResizeThumbStyle" TargetType="Thumb">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Opacity" Value="0.01" />
            <Setter Property="Panel.ZIndex" Value="10" />
            <Setter Property="behaviors:ResizeOnCanvasBehavior.IsEnabled" Value="True" />
        </Style>
    </local:BaseView.Resources>

    <DockPanel>

        <ItemsControl ItemsSource="{Binding FuelDispenserViewModels}">

            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <Canvas Background="Green" />
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>

            <ItemsControl.ItemContainerStyle>
                <Style TargetType="ContentPresenter">
                    <Setter Property="Canvas.Left" Value="{Binding X}" />
                    <Setter Property="Canvas.Top" Value="{Binding Y}" />
                    <Setter Property="Width" Value="{Binding Width}" />
                    <!--<Setter Property="Height" Value="{Binding Height}" />-->
                </Style>
            </ItemsControl.ItemContainerStyle>

            <ItemsControl.ItemTemplate>
                <DataTemplate DataType="{x:Type viewModels:FuelDispenserViewModel}">
                    <Grid behaviors:DragOnCanvasBehavior.IsEnabled="True" Background="Transparent">
                        <Border
                            Padding="3"
                            Background="White"
                            BorderBrush="Silver"
                            BorderThickness="5"
                            CornerRadius="3">
                            <Viewbox Grid.Row="2">
                                <customControls:FuelTransferColumnControl />
                            </Viewbox>
                        </Border>

                        <!--  Углы  -->
                        <!--<Thumb
                            Width="10"
                            Height="10"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Top"
                            behaviors:ResizeOnCanvasBehavior.Direction="TopLeft"
                            Cursor="SizeNWSE"
                            Style="{StaticResource ResizeThumbStyle}" />-->

                        <!--<Thumb
                            Width="10"
                            Height="10"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Top"
                            behaviors:ResizeOnCanvasBehavior.Direction="TopRight"
                            Cursor="SizeNESW"
                            Style="{StaticResource ResizeThumbStyle}" />-->

                        <!--<Thumb
                            Width="10"
                            Height="10"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Bottom"
                            behaviors:ResizeOnCanvasBehavior.Direction="BottomLeft"
                            Cursor="SizeNESW"
                            Style="{StaticResource ResizeThumbStyle}" />

                        <Thumb
                            Width="10"
                            Height="10"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Bottom"
                            behaviors:ResizeOnCanvasBehavior.Direction="BottomRight"
                            Cursor="SizeNWSE"
                            Style="{StaticResource ResizeThumbStyle}" />-->

                        <!--  Стороны  -->
                        <Thumb
                            Width="6"
                            Height="Auto"
                            Margin="0,10"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Stretch"
                            behaviors:ResizeOnCanvasBehavior.Direction="Left"
                            Cursor="SizeWE"
                            Style="{StaticResource ResizeThumbStyle}" />

                        <Thumb
                            Width="6"
                            Height="Auto"
                            Margin="0,10"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Stretch"
                            behaviors:ResizeOnCanvasBehavior.Direction="Right"
                            Cursor="SizeWE"
                            Style="{StaticResource ResizeThumbStyle}" />

                        <!--<Thumb
                            Width="Auto"
                            Height="6"
                            Margin="10,0"
                            HorizontalAlignment="Stretch"
                            VerticalAlignment="Top"
                            behaviors:ResizeOnCanvasBehavior.Direction="Top"
                            Cursor="SizeNS"
                            Style="{StaticResource ResizeThumbStyle}" />-->

                        <!--<Thumb
                            Width="Auto"
                            Height="6"
                            Margin="10,0"
                            HorizontalAlignment="Stretch"
                            VerticalAlignment="Bottom"
                            behaviors:ResizeOnCanvasBehavior.Direction="Bottom"
                            Cursor="SizeNS"
                            Style="{StaticResource ResizeThumbStyle}" />-->

                    </Grid>
                </DataTemplate>
            </ItemsControl.ItemTemplate>

            <d:ItemsControl.Items>
                1
            </d:ItemsControl.Items>

            <dxmvvm:Interaction.Behaviors>
                <dxmvvm:EventToCommand
                    Command="{Binding ItemsControlLoadedCommand}"
                    EventName="Loaded"
                    PassEventArgsToCommand="True" />
            </dxmvvm:Interaction.Behaviors>

        </ItemsControl>

    </DockPanel>

</local:BaseView>
