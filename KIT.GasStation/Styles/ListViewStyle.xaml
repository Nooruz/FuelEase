<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:dxb="http://schemas.devexpress.com/winfx/2008/xaml/bars"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:controls="clr-namespace:KIT.GasStation.Controls"
                    xmlns:converters="clr-namespace:KIT.GasStation.Converters"
                    xmlns:views="clr-namespace:KIT.GasStation.Views.Base"
                    xmlns:dxdo="http://schemas.devexpress.com/winfx/2008/xaml/docking"
                    xmlns:customs="clr-namespace:KIT.GasStation.Customs">

    <converters:NozzleMarginConverter x:Key="NozzleMarginConverter"/>

    <Style TargetType="{x:Type ListView}" x:Key="ItemsPanelBaseStyle">

        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>

        <Setter Property="ItemsPanel">
            <Setter.Value>
                <ItemsPanelTemplate>
                    <WrapPanel Orientation="Horizontal"/>
                </ItemsPanelTemplate>
            </Setter.Value>
        </Setter>

    </Style>

    <Style TargetType="{x:Type ListView}" x:Key="TankListView" BasedOn="{StaticResource ItemsPanelBaseStyle}">
        <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled"/>
        <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto"/>
        <Setter Property="ItemContainerStyle">
            <Setter.Value>
                <Style TargetType="ListViewItem">
                    <Setter Property="Margin" Value="6"/>
                </Style>
            </Setter.Value>
        </Setter>
        <Setter Property="ItemTemplate">
            <Setter.Value>
                <DataTemplate>
                    <controls:TankControl/>
                </DataTemplate>
            </Setter.Value>
        </Setter>

    </Style>

    <Style TargetType="{x:Type GroupItem}" x:Key="FuelNozzleGroupItemStyle">
        <Setter Property="BorderBrush" Value="Blue"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type GroupItem}">

                    <Border BorderThickness="3"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            Padding="10"
                            Width="225"
                            Margin="10">

                        <Grid>

                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <Border Background="{StaticResource FuelNozzleSelectedColorBrush}">

                                <TextBlock Text="{Binding Name, StringFormat='{}- {0} -'}"
                                           FontSize="22"
                                           HorizontalAlignment="Center"
                                           Foreground="Black"/>

                            </Border>

                            <ItemsPresenter Grid.Row="1"
                                            x:Name="Items"/>

                            <StackPanel Grid.Row="2">

                                <Border Height="30"
                                        Background="{StaticResource FuelNozzleSelectedColorBrush}">
                                    <TextBlock TextAlignment="Center"
                                               FontSize="18"
                                               FontWeight="Bold"
                                               Grid.Row="2"
                                               x:Name="PaymentType"/>
                                </Border>

                                <Border Height="30"
                                        Background="{StaticResource FuelNozzleSelectedColorBrush}">

                                    <Grid>

                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition/>
                                            <ColumnDefinition/>
                                        </Grid.ColumnDefinitions>

                                        <TextBlock x:Name="Quantity"
                                                   FontSize="18"
                                                   TextAlignment="Center"
                                                   FontWeight="Bold"/>

                                        <TextBlock x:Name="Sum"
                                                   Grid.Column="1"
                                                   FontSize="18"
                                                   TextAlignment="Center"
                                                   FontWeight="Bold"/>

                                    </Grid>

                                </Border>

                                <Border Height="30"
                                        Background="{StaticResource FuelNozzleSelectedColorBrush}">

                                    <Grid>

                                        <ProgressBar Minimum="0"
                                                     x:Name="Progress"
                                                     Grid.Column="0"
                                                     Grid.ColumnSpan="2"/>

                                        <Grid>

                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition/>
                                                <ColumnDefinition/>
                                            </Grid.ColumnDefinitions>

                                            <TextBlock FontSize="18"
                                                       TextAlignment="Center"
                                                       FontWeight="Bold"
                                                       Text="{Binding Items, Converter={StaticResource ReceivedConverter}, ConverterParameter='ReceivedQuantity'}"/>

                                            <TextBlock Grid.Column="1"
                                                       FontSize="18"
                                                       TextAlignment="Center"
                                                       FontWeight="Bold"
                                                       Text="{Binding Items, Converter={StaticResource ReceivedConverter}, ConverterParameter='ReceivedSum'}"/>



                                        </Grid>

                                    </Grid>

                                </Border>

                            </StackPanel>

                        </Grid>

                    </Border>

                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="{x:Type ListView}" x:Key="NozzleListView">

        <Setter Property="ItemsPanel">
            <Setter.Value>
                <ItemsPanelTemplate>
                    <StackPanel/>
                </ItemsPanelTemplate>
            </Setter.Value>
        </Setter>

        <Setter Property="ItemContainerStyle">
            <Setter.Value>

                <Style TargetType="ListViewItem">

                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                    <Setter Property="VerticalContentAlignment" Value="Stretch"/>
                    <Setter Property="Margin">
                        <Setter.Value>
                            <MultiBinding Converter="{StaticResource NozzleMarginConverter}">
                                <Binding RelativeSource="{RelativeSource Self}"/>
                                <Binding RelativeSource="{RelativeSource AncestorType={x:Type ListView}}" Path="Items.Count"/>
                            </MultiBinding>
                        </Setter.Value>
                    </Setter>
                    <Setter Property="Background">
                        <Setter.Value>
                            <MultiBinding Converter="{StaticResource NozzleStatusToBackgroundConverter}">
                                <Binding Path="Status"/>
                                <Binding Path="Selected"/>
                                <!--<Binding Path="ControlMode"/>-->
                            </MultiBinding>
                        </Setter.Value>
                    </Setter>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="{x:Type ListViewItem}">
                                <Border Name="Border"
                                        BorderThickness="1"
                                        BorderBrush="{StaticResource NozzleStatusNoneColorBrush}"
                                        SnapsToDevicePixels="True"
                                        Background="{TemplateBinding Background}">
                                    <controls:NozzleControl/>
                                </Border>
                                <!--<ControlTemplate.Triggers>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter Property="Background" Value="{StaticResource NozzleSelectedColorBrush}"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>-->
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                    <Setter Property="dxb:BarManager.DXContextMenu">
                        <Setter.Value>
                            <dxb:PopupMenu>
                                <dxb:PopupMenu.Items>
                                    <dxb:BarButtonItem Content="Остановить" 
                                                       IsEnabled="{Binding Status, Converter={StaticResource NozzlePopupMenuIsEnabledConverter}, ConverterParameter=StopFueling, UpdateSourceTrigger=PropertyChanged}"
                                                       Command="{Binding RelativeSource={RelativeSource AncestorType={x:Type UserControl}, Mode=FindAncestor}, Path=DataContext.StopFuelingCommand}"/>
                                    <dxb:BarItemSeparator/>
                                    <dxb:BarButtonItem Content="Продолжить" 
                                                       IsEnabled="{Binding Status, Converter={StaticResource NozzlePopupMenuIsEnabledConverter}, ConverterParameter=ContinueFueling, UpdateSourceTrigger=PropertyChanged}"
                                                       Command="{Binding RelativeSource={RelativeSource AncestorType={x:Type UserControl}, Mode=FindAncestor}, Path=DataContext.ContinueFuelingCommand}"/>
                                    <dxb:BarButtonItem Content="Завершить" 
                                                       IsEnabled="{Binding Status, Converter={StaticResource NozzlePopupMenuIsEnabledConverter}, ConverterParameter=ContinueFueling, UpdateSourceTrigger=PropertyChanged}"
                                                       Command="{Binding RelativeSource={RelativeSource AncestorType={x:Type UserControl}, Mode=FindAncestor}, Path=DataContext.CompleteFuelingCommand}"/>
                                    <dxb:BarButtonItem Content="Освободить"
                                                       IsEnabled="{Binding Status, Converter={StaticResource NozzlePopupMenuIsEnabledConverter}, ConverterParameter=CompleteFueling, UpdateSourceTrigger=PropertyChanged}"
                                                       Command="{Binding ReleaseFuelNozzleCommand}"/>
                                    <dxb:BarItemSeparator/>
                                    <dxb:BarButtonItem Content="Принудительный пуск"/>
                                    <dxb:BarItemSeparator/>
                                    <dxb:BarButtonItem Content="Перекачка"
                                                       IsEnabled="{Binding Status, Converter={StaticResource NozzlePopupMenuIsEnabledConverter}, ConverterParameter=Pumping, UpdateSourceTrigger=PropertyChanged}"
                                                       Command="{Binding PumpingCommand}"/>
                                    <dxb:BarButtonItem Content="Отпуск до полного бака"
                                                       IsEnabled="{Binding Status, Converter={StaticResource NozzlePopupMenuIsEnabledConverter}, ConverterParameter=Pumping, UpdateSourceTrigger=PropertyChanged}"
                                                       Command="{Binding FuelingToFullCommand}"/>
                                    <dxb:BarItemSeparator/>
                                    <dxb:BarButtonItem Content="Чек на последнюю продажу"
                                                       Command="{Binding ElementName=FuelTransferColumn, Path=DataContext.PrintLastReceiptCommand}"/>
                                    <dxb:BarItemSeparator/>
                                    <dxb:BarSubItem Content="Состояние устройства">
                                        <dxb:BarButtonItem Content="Запросить счетчик"
                                                           IsEnabled="{Binding Status, Converter={StaticResource NozzlePopupMenuIsEnabledConverter}, ConverterParameter=Pumping, UpdateSourceTrigger=PropertyChanged}"
                                                           Command="{Binding GetMeterValueCommand}"/>
                                        <!--Блокировать ТРК-->
                                        <dxb:BarButtonItem Content="{Binding Status, Converter={StaticResource BarButtonItemContentConverter}, UpdateSourceTrigger=PropertyChanged, ConverterParameter=Block}"
                                                           Command="{Binding RelativeSource={RelativeSource AncestorType={x:Type UserControl}, Mode=FindAncestor}, Path=DataContext.NozzleBlockCommand}"/>
                                        <!--Включить автономный режим-->
                                        <dxb:BarButtonItem Content="{Binding ControlMode, Converter={StaticResource BarButtonItemContentConverter}, UpdateSourceTrigger=PropertyChanged, ConverterParameter=ControlMode}"
                                                           IsEnabled="{Binding ControlMode, Converter={StaticResource ControlModeToIsEnabledConverter}, UpdateSourceTrigger=PropertyChanged, ConverterParameter=ControlMode}"
                                                           Command="{Binding RelativeSource={RelativeSource AncestorType={x:Type UserControl}, Mode=FindAncestor}, Path=DataContext.ChangeControlModeCommand}"/>
                                    </dxb:BarSubItem>
                                </dxb:PopupMenu.Items>
                            </dxb:PopupMenu>
                        </Setter.Value>
                    </Setter>

                </Style>

            </Setter.Value>
        </Setter>

    </Style>

</ResourceDictionary>