<local:BaseView     x:Class="KIT.GasStation.Views.UserView"
                    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:dxb="http://schemas.devexpress.com/winfx/2008/xaml/bars"
                    xmlns:dx="http://schemas.devexpress.com/winfx/2008/xaml/core"
                    xmlns:dxg="http://schemas.devexpress.com/winfx/2008/xaml/grid"
                    xmlns:dxlc="http://schemas.devexpress.com/winfx/2008/xaml/layoutcontrol"
                    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                    xmlns:local="clr-namespace:KIT.GasStation.Views.Base"
                    mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">

    <dxlc:LayoutControl Orientation="Vertical">

        <dxb:ToolBarControl AllowCustomizationMenu="False"
                            AllowQuickCustomization="False" >
            <dxb:BarButtonItem Content="Создать" 
                               Glyph="{dx:DXImage SvgImages/Icon Builder/Actions_AddCircled.svg}" 
                               BarItemDisplayMode="ContentAndGlyph"
                               Command="{Binding CreateUserCommand}"/>
            <dxb:BarButtonItem Content="Редактировать" 
                               IsEnabled="{Binding SelectedUser.IsAdmin, Converter={StaticResource BooleanConverter}}"
                               Glyph="{dx:DXImage SvgImages/Icon Builder/Actions_Edit.svg}" 
                               BarItemDisplayMode="ContentAndGlyph"
                               Command="{Binding EditUserCommand}"/>
            <dxb:BarButtonItem Content="Удалить" 
                               Glyph="{dx:DXImage SvgImages/Icon Builder/Actions_DeleteCircled.svg}" 
                               BarItemDisplayMode="ContentAndGlyph"
                               IsEnabled="{Binding SelectedUser.IsAdmin, Converter={StaticResource BooleanConverter}}"
                               Command="{Binding DeleteUserCommand}"/>
        </dxb:ToolBarControl>

        <dxg:GridControl ItemsSource="{Binding Users}"
                         SelectedItem="{Binding SelectedUser}">
            <dxg:GridControl.View>
                <dxg:TableView ShowGroupPanel="False"
                               AllowEditing="False"/>
            </dxg:GridControl.View>
            <dxg:GridControl.ContextMenu>
                <ContextMenu>
                    <MenuItem Header="Создать"
                              Command="{Binding CreateUserCommand}"/>
                    <MenuItem Header="Редактировать"
                              IsEnabled="{Binding SelectedUser.IsAdmin, Converter={StaticResource BooleanConverter}}"
                              Command="{Binding EditUserCommand}"/>
                    <MenuItem Header="Удалить"
                              IsEnabled="{Binding SelectedUser.IsAdmin, Converter={StaticResource BooleanConverter}}"
                              Command="{Binding DeleteUserCommand}"/>
                </ContextMenu>
            </dxg:GridControl.ContextMenu>

            <dxg:GridColumn Header="ФИО"
                            FieldName="FullName"/>
            <dxg:GridColumn Header="Логин"
                            FieldName="Login"/>
            <dxg:GridColumn Header="Роль"
                            FieldName="UserRole.Name"/>

        </dxg:GridControl>

    </dxlc:LayoutControl>
    
</local:BaseView>
