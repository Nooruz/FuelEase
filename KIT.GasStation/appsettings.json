{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft": "Warning",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  },
  "ConnectionStrings": {
    "DefaultConnection": "Data Source=.;Initial Catalog=FuelEaseDb;Integrated Security=True;Encrypt=True;TrustServerCertificate=True"
  },

  "SignalR": {
    "BaseUrl": "http://localhost:5005",
    "HubPath": "/deviceresponse",
    "IgnoreSslErrors": false
  },
  "Services": {
    "WebName": "KITWeb",
    "WorkerName": "KITWorker",
    "StartTimeoutSeconds": 60,
    "StopTimeoutSeconds": 60
  }
}

