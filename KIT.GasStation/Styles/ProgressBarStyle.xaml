<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="clr-namespace:KIT.GasStation.Converters">

    <converters:ProgressToScaleYConverter x:Key="ProgressToScaleYConverter" />

    <Style x:Key="ReservoirProgressBar" TargetType="{x:Type ProgressBar}">

        <!--  Зададим умолчания, чтобы не забыть  -->
        <Setter Property="BorderBrush" Value="Black" />
        <Setter Property="BorderThickness" Value="2" />
        <Setter Property="Background" Value="White" /> 
        <!--  «Пустая» часть  -->
        <Setter Property="Foreground" Value="Red" /> 
        <!--  «Заливка» (прогресс)  -->

        <!--  Поворот на -90°, если нужно «вертикальное» отображение  -->
        <Setter Property="LayoutTransform">
            <Setter.Value>
                <RotateTransform Angle="-90" CenterX="0.5" CenterY="0.5" />
            </Setter.Value>
        </Setter>

        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type ProgressBar}">

                    <!--  Общий контейнер  -->
                    <Grid x:Name="TemplateRoot" SnapsToDevicePixels="true">

                        <!--
                        1) "Основная" рамка, рисует чёрную обводку и «фон» (Background)
                           Фон — это то, что видно «под заливкой», когда прогресс < 100%.
                           BorderThickness=2 => чёрная обводка в 2 пикселя.
                        -->
                        <Border
                            x:Name="Container"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="100" />

                        <!--
                            2) Внутренний Grid с OpacityMask, чтобы заливка «вырезалась»
                            по форме рамки Container (CornerRadius и т.д.).
                        -->
                        <Grid>
                            <Grid.OpacityMask>
                                <VisualBrush Visual="{Binding ElementName=Container}" />
                            </Grid.OpacityMask>

                            <!--
                                Трек (полоса), можно оставить Fill="Transparent"
                                или убрать совсем, если не нужен
                            -->
                            <Rectangle x:Name="PART_Track" Fill="Transparent" />

                            <!--
                                3) «Индикатор» прогресса.
                                ClipToBounds="True" + HorizontalAlignment="Left"
                                используется для «обрезания» по ширине (или высоте)
                                по мере изменения Value.
                            -->
                            <Grid
                                x:Name="PART_Indicator"
                                HorizontalAlignment="Left"
                                ClipToBounds="True">

                                <Rectangle x:Name="Indicator" Fill="{TemplateBinding Foreground}" />

                                <!--
                                    Если используете анимацию «полосок»,
                                    оставьте Rectangle "Animation"
                                    и соответствующую логику анимации.
                                -->
                                <Rectangle x:Name="Animation" Fill="{TemplateBinding Foreground}">
                                    <Rectangle.RenderTransform>
                                        <TransformGroup>
                                            <ScaleTransform />
                                            <SkewTransform />
                                            <RotateTransform />
                                            <TranslateTransform />
                                        </TransformGroup>
                                    </Rectangle.RenderTransform>
                                </Rectangle>
                            </Grid>
                        </Grid>

                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="RoundedProgressBarVerticalBottomUpCornered" TargetType="{x:Type ProgressBar}">
        <Setter Property="Foreground" Value="#FFAD16" />
        <Setter Property="Background" Value="White" />
        <Setter Property="BorderBrush" Value="Silver" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Border.CornerRadius" Value="5" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ProgressBar">
                    <Grid x:Name="Root">
                        <Border
                            Name="PART_Track"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="{TemplateBinding Border.CornerRadius}" />
                        <Border
                            Name="PART_Indicator"
                            HorizontalAlignment="Left"
                            Background="{TemplateBinding Foreground}"
                            BorderBrush="Transparent"
                            BorderThickness="{TemplateBinding BorderThickness}">
                            <Border.CornerRadius>
                                <MultiBinding Converter="{StaticResource ProgressToScaleYConverter}">
                                    <Binding Path="Value" RelativeSource="{RelativeSource TemplatedParent}" />
                                    <Binding Path="Minimum" RelativeSource="{RelativeSource TemplatedParent}" />
                                    <Binding Path="Maximum" RelativeSource="{RelativeSource TemplatedParent}" />
                                </MultiBinding>
                            </Border.CornerRadius>
                        </Border>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <!--  Getting vertical style working using technique described here: http://stackoverflow.com/a/6849237/7532  -->
                        <Trigger Property="Orientation" Value="Horizontal">
                            <Setter TargetName="Root" Property="LayoutTransform">
                                <Setter.Value>
                                    <RotateTransform Angle="270" />
                                </Setter.Value>
                            </Setter>

                            <Setter TargetName="Root" Property="Width" Value="{Binding RelativeSource={RelativeSource TemplatedParent}, Path=Height}" />
                            <Setter TargetName="Root" Property="Height" Value="{Binding RelativeSource={RelativeSource TemplatedParent}, Path=Width}" />
                        </Trigger>
                    </ControlTemplate.Triggers>

                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="RoundedProgressBarVerticalBottomUp" TargetType="{x:Type ProgressBar}">
        <Setter Property="Foreground" Value="#FFAD16" />
        <Setter Property="Background" Value="White" />
        <Setter Property="BorderBrush" Value="Silver" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ProgressBar">
                    <Grid x:Name="Root">
                        <Border
                            Name="PART_Track"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}" />
                        <Border
                            Name="PART_Indicator"
                            HorizontalAlignment="Left"
                            Background="{TemplateBinding Foreground}"
                            BorderBrush="Transparent"
                            BorderThickness="{TemplateBinding BorderThickness}" />
                    </Grid>
                    <ControlTemplate.Triggers>
                        <!--  Getting vertical style working using technique described here: http://stackoverflow.com/a/6849237/7532  -->
                        <Trigger Property="Orientation" Value="Horizontal">
                            <Setter TargetName="Root" Property="LayoutTransform">
                                <Setter.Value>
                                    <RotateTransform Angle="270" />
                                </Setter.Value>
                            </Setter>

                            <Setter TargetName="Root" Property="Width" Value="{Binding RelativeSource={RelativeSource TemplatedParent}, Path=Height}" />
                            <Setter TargetName="Root" Property="Height" Value="{Binding RelativeSource={RelativeSource TemplatedParent}, Path=Width}" />
                        </Trigger>
                    </ControlTemplate.Triggers>

                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>


</ResourceDictionary>
