<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:KIT.GasStation.Controls"
    xmlns:converters="clr-namespace:KIT.GasStation.Converters"
    xmlns:customs="clr-namespace:KIT.GasStation.Customs"
    xmlns:dxb="http://schemas.devexpress.com/winfx/2008/xaml/bars"
    xmlns:dxdo="http://schemas.devexpress.com/winfx/2008/xaml/docking"
    xmlns:views="clr-namespace:KIT.GasStation.Views.Base">

    <converters:NozzleMarginConverter x:Key="NozzleMarginConverter" />

    <Style x:Key="ItemsPanelBaseStyle" TargetType="{x:Type ListView}">

        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />

        <Setter Property="ItemsPanel">
            <Setter.Value>
                <ItemsPanelTemplate>
                    <WrapPanel Orientation="Horizontal" />
                </ItemsPanelTemplate>
            </Setter.Value>
        </Setter>

    </Style>

    <Style
        x:Key="TankListView"
        BasedOn="{StaticResource ItemsPanelBaseStyle}"
        TargetType="{x:Type ListView}">
        <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled" />
        <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto" />
        <Setter Property="ItemContainerStyle">
            <Setter.Value>
                <Style TargetType="ListViewItem">
                    <Setter Property="Margin" Value="6" />
                </Style>
            </Setter.Value>
        </Setter>
        <Setter Property="ItemTemplate">
            <Setter.Value>
                <DataTemplate>
                    <controls:TankControl />
                </DataTemplate>
            </Setter.Value>
        </Setter>

    </Style>

    <Style x:Key="FuelNozzleGroupItemStyle" TargetType="{x:Type GroupItem}">
        <Setter Property="BorderBrush" Value="Blue" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type GroupItem}">

                    <Border
                        Width="225"
                        Margin="10"
                        Padding="10"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="3">

                        <Grid>

                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <Border Background="{StaticResource FuelNozzleSelectedColorBrush}">

                                <TextBlock
                                    HorizontalAlignment="Center"
                                    FontSize="22"
                                    Foreground="Black"
                                    Text="{Binding Name, StringFormat='{}- {0} -'}" />

                            </Border>

                            <ItemsPresenter x:Name="Items" Grid.Row="1" />

                            <StackPanel Grid.Row="2">

                                <Border Height="30" Background="{StaticResource FuelNozzleSelectedColorBrush}">
                                    <TextBlock
                                        x:Name="PaymentType"
                                        Grid.Row="2"
                                        FontSize="18"
                                        FontWeight="Bold"
                                        TextAlignment="Center" />
                                </Border>

                                <Border Height="30" Background="{StaticResource FuelNozzleSelectedColorBrush}">

                                    <Grid>

                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition />
                                            <ColumnDefinition />
                                        </Grid.ColumnDefinitions>

                                        <TextBlock
                                            x:Name="Quantity"
                                            FontSize="18"
                                            FontWeight="Bold"
                                            TextAlignment="Center" />

                                        <TextBlock
                                            x:Name="Sum"
                                            Grid.Column="1"
                                            FontSize="18"
                                            FontWeight="Bold"
                                            TextAlignment="Center" />

                                    </Grid>

                                </Border>

                                <Border Height="30" Background="{StaticResource FuelNozzleSelectedColorBrush}">

                                    <Grid>

                                        <ProgressBar
                                            x:Name="Progress"
                                            Grid.Column="0"
                                            Grid.ColumnSpan="2"
                                            Minimum="0" />

                                        <Grid>

                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition />
                                                <ColumnDefinition />
                                            </Grid.ColumnDefinitions>

                                            <TextBlock
                                                FontSize="18"
                                                FontWeight="Bold"
                                                Text="{Binding Items, Converter={StaticResource ReceivedConverter}, ConverterParameter='ReceivedQuantity'}"
                                                TextAlignment="Center" />

                                            <TextBlock
                                                Grid.Column="1"
                                                FontSize="18"
                                                FontWeight="Bold"
                                                Text="{Binding Items, Converter={StaticResource ReceivedConverter}, ConverterParameter='ReceivedSum'}"
                                                TextAlignment="Center" />



                                        </Grid>

                                    </Grid>

                                </Border>

                            </StackPanel>

                        </Grid>

                    </Border>

                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="NozzleListView" TargetType="{x:Type ListView}">

        <Setter Property="ItemsPanel">
            <Setter.Value>
                <ItemsPanelTemplate>
                    <StackPanel />
                </ItemsPanelTemplate>
            </Setter.Value>
        </Setter>

        <Setter Property="ItemContainerStyle">
            <Setter.Value>

                <Style TargetType="ListViewItem">

                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                    <Setter Property="VerticalContentAlignment" Value="Stretch" />
                    <Setter Property="Margin">
                        <Setter.Value>
                            <MultiBinding Converter="{StaticResource NozzleMarginConverter}">
                                <Binding RelativeSource="{RelativeSource Self}" />
                                <Binding Path="Items.Count" RelativeSource="{RelativeSource AncestorType={x:Type ListView}}" />
                            </MultiBinding>
                        </Setter.Value>
                    </Setter>
                    <Setter Property="Background">
                        <Setter.Value>
                            <MultiBinding Converter="{StaticResource NozzleStatusToBackgroundConverter}">
                                <Binding Path="Status" />
                                <Binding Path="Selected" />
                                <!--<Binding Path="ControlMode"/>-->
                            </MultiBinding>
                        </Setter.Value>
                    </Setter>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="{x:Type ListViewItem}">
                                <Border
                                    Name="Border"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{StaticResource NozzleStatusNoneColorBrush}"
                                    BorderThickness="1"
                                    SnapsToDevicePixels="True">
                                    <controls:NozzleControl />
                                </Border>
                                <!--<ControlTemplate.Triggers>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter Property="Background" Value="{StaticResource NozzleSelectedColorBrush}"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>-->
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                    <Setter Property="dxb:BarManager.DXContextMenu">
                        <Setter.Value>
                            <dxb:PopupMenu>
                                <dxb:PopupMenu.Items>
                                    <dxb:BarButtonItem
                                        Command="{Binding RelativeSource={RelativeSource AncestorType={x:Type UserControl}, Mode=FindAncestor}, Path=DataContext.StopFuelingCommand}"
                                        Content="Остановить"
                                        IsEnabled="{Binding Status, Converter={StaticResource NozzlePopupMenuIsEnabledConverter}, ConverterParameter=StopFueling, UpdateSourceTrigger=PropertyChanged}" />
                                    <dxb:BarItemSeparator />
                                    <dxb:BarButtonItem
                                        Command="{Binding RelativeSource={RelativeSource AncestorType={x:Type UserControl}, Mode=FindAncestor}, Path=DataContext.ContinueFuelingCommand}"
                                        Content="Продолжить"
                                        IsEnabled="{Binding Status, Converter={StaticResource NozzlePopupMenuIsEnabledConverter}, ConverterParameter=ContinueFueling, UpdateSourceTrigger=PropertyChanged}" />
                                    <dxb:BarButtonItem
                                        Command="{Binding RelativeSource={RelativeSource AncestorType={x:Type UserControl}, Mode=FindAncestor}, Path=DataContext.CompleteFuelingCommand}"
                                        Content="Завершить"
                                        IsEnabled="{Binding Status, Converter={StaticResource NozzlePopupMenuIsEnabledConverter}, ConverterParameter=ContinueFueling, UpdateSourceTrigger=PropertyChanged}" />
                                    <dxb:BarButtonItem
                                        Command="{Binding ReleaseFuelNozzleCommand}"
                                        Content="Освободить"
                                        IsEnabled="{Binding Status, Converter={StaticResource NozzlePopupMenuIsEnabledConverter}, ConverterParameter=CompleteFueling, UpdateSourceTrigger=PropertyChanged}" />
                                    <dxb:BarItemSeparator />
                                    <dxb:BarButtonItem Content="Принудительный пуск" />
                                    <dxb:BarItemSeparator />
                                    <dxb:BarButtonItem
                                        Command="{Binding PumpingCommand}"
                                        Content="Перекачка"
                                        IsEnabled="{Binding Status, Converter={StaticResource NozzlePopupMenuIsEnabledConverter}, ConverterParameter=Pumping, UpdateSourceTrigger=PropertyChanged}" />
                                    <dxb:BarButtonItem
                                        Command="{Binding FuelingToFullCommand}"
                                        Content="Отпуск до полного бака"
                                        IsEnabled="{Binding Status, Converter={StaticResource NozzlePopupMenuIsEnabledConverter}, ConverterParameter=Pumping, UpdateSourceTrigger=PropertyChanged}" />
                                    <dxb:BarItemSeparator />
                                    <dxb:BarButtonItem Command="{Binding ElementName=FuelTransferColumn, Path=DataContext.PrintLastReceiptCommand}" Content="Чек на последнюю продажу" />
                                    <dxb:BarItemSeparator />
                                    <dxb:BarSubItem Content="Состояние устройства">
                                        <dxb:BarButtonItem
                                            Command="{Binding GetMeterValueCommand}"
                                            Content="Запросить счетчик"
                                            IsEnabled="{Binding Status, Converter={StaticResource NozzlePopupMenuIsEnabledConverter}, ConverterParameter=Pumping, UpdateSourceTrigger=PropertyChanged}" />
                                        <!--  Блокировать ТРК  -->
                                        <dxb:BarButtonItem Command="{Binding RelativeSource={RelativeSource AncestorType={x:Type UserControl}, Mode=FindAncestor}, Path=DataContext.NozzleBlockCommand}" Content="{Binding Status, Converter={StaticResource BarButtonItemContentConverter}, UpdateSourceTrigger=PropertyChanged, ConverterParameter=Block}" />
                                        <!--  Включить автономный режим  -->
                                        <dxb:BarButtonItem
                                            Command="{Binding RelativeSource={RelativeSource AncestorType={x:Type UserControl}, Mode=FindAncestor}, Path=DataContext.ChangeControlModeCommand}"
                                            Content="{Binding ControlMode, Converter={StaticResource BarButtonItemContentConverter}, UpdateSourceTrigger=PropertyChanged, ConverterParameter=ControlMode}"
                                            IsEnabled="{Binding ControlMode, Converter={StaticResource ControlModeToIsEnabledConverter}, UpdateSourceTrigger=PropertyChanged, ConverterParameter=ControlMode}" />
                                    </dxb:BarSubItem>
                                </dxb:PopupMenu.Items>
                            </dxb:PopupMenu>
                        </Setter.Value>
                    </Setter>

                </Style>

            </Setter.Value>
        </Setter>

    </Style>

</ResourceDictionary>
