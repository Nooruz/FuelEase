<dx:ThemedWindow
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:dx="http://schemas.devexpress.com/winfx/2008/xaml/core"
    xmlns:dxmvvm="http://schemas.devexpress.com/winfx/2008/xaml/mvvm"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:local="clr-namespace:FuelEase"
    xmlns:splashScreen="clr-namespace:FuelEase.SplashScreen.ThemedSplashScreen"
    x:Class="FuelEase.MainWindow"
    mc:Ignorable="d"
    WindowState="Maximized"
    Title="{x:Static local:App.ProductName}" 
    MinHeight="450" 
    MinWidth="800">
    <dxmvvm:Interaction.Behaviors>
        <dxmvvm:NotificationService/>
        <dx:SplashScreenManagerService SplashScreenType="{x:Type splashScreen:ProgressWindow}"/>
        <dxmvvm:EventToCommand EventName="Closing"
                               Command="{Binding ClosingCommand}"
                               PassEventArgsToCommand="True"/>
        <dx:DXMessageBoxService/>
    </dxmvvm:Interaction.Behaviors>

    <ContentControl Content="{Binding CurrentViewModel, UpdateSourceTrigger=PropertyChanged}"/>

</dx:ThemedWindow>
