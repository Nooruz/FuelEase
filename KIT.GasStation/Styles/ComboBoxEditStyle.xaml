<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:dxe="http://schemas.devexpress.com/winfx/2008/xaml/editors">

    <Style TargetType="{x:Type dxe:ComboBoxEdit}" x:Key="HardwareConfigurationDetailView">
        <Style.Triggers>
            <DataTrigger Binding="{Binding Path=DataContext.HardWareType, RelativeSource={RelativeSource AncestorType=UserControl}}"
                         Value="FuelTransferColumn">
                <Setter Property="ItemsSource" Value="{Binding FuelTransferColumnTypes}"/>
                <Setter Property="EditValue" Value="{Binding SelectedFuelTransferColumnType}"/>
            </DataTrigger>
            <DataTrigger Binding="{Binding Path=DataContext.HardWareType, RelativeSource={RelativeSource AncestorType=UserControl}}"
                         Value="CashRegister">
                <Setter Property="ItemsSource" Value="{Binding CashRegisterTypes}"/>
                <Setter Property="EditValue" Value="{Binding SelectedCashRegisterType}"/>
            </DataTrigger>
        </Style.Triggers>
    </Style>
    
</ResourceDictionary>