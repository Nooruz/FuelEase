<local:BaseView x:Class="KIT.GasStation.Hardware.Views.AuthorizationServerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:dxb="http://schemas.devexpress.com/winfx/2008/xaml/bars"
             xmlns:dxe="http://schemas.devexpress.com/winfx/2008/xaml/editors"
             xmlns:dxlc="http://schemas.devexpress.com/winfx/2008/xaml/layoutcontrol"
             xmlns:dx="http://schemas.devexpress.com/winfx/2008/xaml/core"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:KIT.GasStation.Hardware.Views"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">

    <dx:LoadingDecorator FadeInDuration="0" FadeOutDuration="0:0:0:1">

        <dxlc:LayoutControl Orientation="Vertical">

            <dxlc:LayoutItem Label="Адрес">
                <dxe:TextEdit EditValue="{Binding SelectedCashRegister.Address, UpdateSourceTrigger=PropertyChanged}"/>
            </dxlc:LayoutItem>

            <dxlc:LayoutGroup Header="Реквизиты подключения" 
                  View="GroupBox"
                  Orientation="Vertical">

                <dxlc:LayoutItem Label="ИНН">
                    <dxe:TextEdit EditValue="{Binding SelectedCashRegister.RegistrationNumber, UpdateSourceTrigger=PropertyChanged}"/>
                </dxlc:LayoutItem>

            </dxlc:LayoutGroup>

            <dxlc:LayoutGroup Header="Реквизиты АЗС" 
                  View="GroupBox"
                  Orientation="Vertical">

                <dxlc:LayoutItem Label="Наименование">
                    <dxe:TextEdit EditValue="{Binding SelectedCashRegister.RegistrationNumber, UpdateSourceTrigger=PropertyChanged}"/>
                </dxlc:LayoutItem>

                <dxlc:LayoutItem Label="Адрес">
                    <dxe:ComboBoxEdit ItemsSource="{Binding TapeTypes}"
                                  EditValue="{Binding SelectedCashRegister.Settings.TapeType, UpdateSourceTrigger=PropertyChanged}"/>
                </dxlc:LayoutItem>

            </dxlc:LayoutGroup>

            <dxlc:LayoutGroup>

                <dxb:ToolBarControl Style="{StaticResource BaseToolBarControl}">
                    <dxb:BarButtonItem Content="Сохранить настройки"
                                   Command="{Binding SaveCommand}" Glyph="{dx:DXImage SvgImages/XAF/Action_SaveScript.svg}"/>
                    <dxb:BarButtonItem Content="Состояние подключении"
                                       Command="{Binding StateCommand}" 
                                       Glyph="{dx:DXImage SvgImages/XAF/State_Validation_Valid.svg}"/>
                    <dxb:BarButtonItem Content="Открыть смену"
                                       Command="{Binding OpenShiftCommand}" Glyph="{dx:DXImage SvgImages/XAF/State_Task_InProgress.svg}"/>
                    <dxb:BarButtonItem Content="Закрыть смену"
                                       Command="{Binding CloseShiftCommand}" Glyph="{dx:DXImage SvgImages/Icon Builder/Actions_Clock.svg}"/>
                </dxb:ToolBarControl>


            </dxlc:LayoutGroup>

        </dxlc:LayoutControl>

    </dx:LoadingDecorator>

</local:BaseView>
