<local:BaseView   x:Class="FuelEase.Views.ConfigurationManagementView"
               xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
               xmlns:dxwui="http://schemas.devexpress.com/winfx/2008/xaml/windowsui"
               xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
               xmlns:customs="clr-namespace:FuelEase.Customs"
               xmlns:local="clr-namespace:FuelEase.Views.Base"
               MinWidth="800"
               MinHeight="600">

    <UserControl.Resources>
        <Style TargetType="{x:Type dxwui:HamburgerMenuNavigationButton}"
               BasedOn="{StaticResource DefaultHamburgerMenuNavigationButton}"/>
    </UserControl.Resources>

    <customs:CustomHamburgerMenu Header="Управления конфигурацией"
                                 OpenPaneWidth="280"
                                 Style="{StaticResource CustomHamburgerMenu}"
                                 AllowBuiltInNavigation="True"
                                 Contents="{Binding CurrentViewModels}"
                                 SelectedBaseViewModel="{Binding CurrentViewModel, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">

        <dxwui:HamburgerMenuNavigationButton Content="Пользователи"
                                             Tag="{StaticResource faUsers}"
                                             CommandParameter="UserView"/>
        
        <dxwui:HamburgerMenuNavigationButton Content="Топлива и резервуары"
                                             Tag="{StaticResource faGasPump}"
                                             CommandParameter="TanksView"/>

        <dxwui:HamburgerMenuNavigationButton Content="Настройки"
                                             Tag="{StaticResource faCogs}"
                                             Command="{Binding SettingsCommand}"/>

    </customs:CustomHamburgerMenu>
    
</local:BaseView>
