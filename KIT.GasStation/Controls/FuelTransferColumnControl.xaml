<UserControl xmlns:dxlc="http://schemas.devexpress.com/winfx/2008/xaml/layoutcontrol" 
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:view="clr-namespace:KIT.GasStation.Views.Base"
    xmlns:dxga="http://schemas.devexpress.com/winfx/2008/xaml/gauges"
    xmlns:dxdo="http://schemas.devexpress.com/winfx/2008/xaml/docking"
    xmlns:dxb="http://schemas.devexpress.com/winfx/2008/xaml/bars"
    xmlns:dxmvvm="http://schemas.devexpress.com/winfx/2008/xaml/mvvm"
    xmlns:dxe="http://schemas.devexpress.com/winfx/2008/xaml/editors"
    x:Class="KIT.GasStation.Controls.FuelTransferColumnControl"
    Margin="3"
    xmlns:control="clr-namespace:KIT.GasStation.Controls"
    Background="{StaticResource WhiteColorBrush}">

    <UserControl.Resources>
        <dxb:PopupMenu x:Key="Menu">
             <dxb:PopupMenu.Items>
                 <dxb:BarButtonItem Content="Остановить" 
                                    IsEnabled="{Binding Status, Converter={StaticResource IsFuelTransperControllerContextMenuEnabledConverter}, ConverterParameter=StopFilling, UpdateSourceTrigger=PropertyChanged}"
                                    Command="{Binding RelativeSource={RelativeSource AncestorType={x:Type UserControl}, Mode=FindAncestor}, Path=DataContext.StopFillingCommand}"/>
                 <dxb:BarItemSeparator/>
                 <dxb:BarButtonItem Content="Продолжить" 
                                    IsEnabled="{Binding Status, Converter={StaticResource IsFuelTransperControllerContextMenuEnabledConverter}, ConverterParameter=ContinueFilling, UpdateSourceTrigger=PropertyChanged}"
                                    Command="{Binding RelativeSource={RelativeSource AncestorType={x:Type UserControl}, Mode=FindAncestor}, Path=DataContext.ContinueFillingCommand}"/>
                 <dxb:BarButtonItem Content="Завершить" 
                                    IsEnabled="{Binding Status, Converter={StaticResource IsFuelTransperControllerContextMenuEnabledConverter}, ConverterParameter=ContinueFilling, UpdateSourceTrigger=PropertyChanged}"
                                    Command="{Binding RelativeSource={RelativeSource AncestorType={x:Type UserControl}, Mode=FindAncestor}, Path=DataContext.CompleteFillingCommand}"/>
                 <dxb:BarButtonItem Content="Освободить"
                                    IsEnabled="{Binding Status, Converter={StaticResource IsFuelTransperControllerContextMenuEnabledConverter}, ConverterParameter=CompleteFilling, UpdateSourceTrigger=PropertyChanged}"
                                    Command="{Binding ReleaseFuelNozzleCommand}"/>
                 <dxb:BarItemSeparator/>
                 <dxb:BarButtonItem Content="Принудительный пуск"/>
                 <dxb:BarItemSeparator/>
                 <dxb:BarButtonItem Content="Перекачка"
                                    IsEnabled="{Binding Status, Converter={StaticResource IsFuelTransperControllerContextMenuEnabledConverter}, ConverterParameter=Pumping, UpdateSourceTrigger=PropertyChanged}"
                                    Command="{Binding PumpingCommand}"/>
                 <dxb:BarButtonItem Content="Отпуск до полного бака"
                                    IsEnabled="{Binding Status, Converter={StaticResource IsFuelTransperControllerContextMenuEnabledConverter}, ConverterParameter=Pumping, UpdateSourceTrigger=PropertyChanged}"
                                    Command="{Binding FillingToFullCommand}"/>
                 <dxb:BarItemSeparator/>
                 <dxb:BarButtonItem Content="Чек на последнюю продажу"
                                    Command="{Binding ElementName=FuelTransferColumn, Path=DataContext.PrintLastReceiptCommand}"/>
                 <dxb:BarItemSeparator/>
                 <dxb:BarSubItem Content="Состояние устройства">
                 <dxb:BarButtonItem Content="Запросить счетчик"
                                    IsEnabled="{Binding Status, Converter={StaticResource IsFuelTransperControllerContextMenuEnabledConverter}, ConverterParameter=Pumping, UpdateSourceTrigger=PropertyChanged}"
                                    Command="{Binding GetMeterValueCommand}"/>
                     
                 <!--Блокировать ТРК-->
                 <dxb:BarButtonItem Content="{Binding Status, Converter={StaticResource BarButtonItemContentConverter}, UpdateSourceTrigger=PropertyChanged, ConverterParameter=Block}"
                                    Command="{Binding RelativeSource={RelativeSource AncestorType={x:Type UserControl}, Mode=FindAncestor}, Path=DataContext.NozzleBlockCommand}"/>
                     
                 <!--Включить автономный режим-->
                 <dxb:BarButtonItem Content="{Binding ControlMode, Converter={StaticResource BarButtonItemContentConverter}, UpdateSourceTrigger=PropertyChanged, ConverterParameter=ControlMode}"
                                    IsEnabled="{Binding ControlMode, Converter={StaticResource ControlModeToIsEnabledConverter}, UpdateSourceTrigger=PropertyChanged, ConverterParameter=ControlMode}"
                                    Command="{Binding RelativeSource={RelativeSource AncestorType={x:Type UserControl}, Mode=FindAncestor}, Path=DataContext.ChangeControlModeCommand}"/>
                 </dxb:BarSubItem>
             </dxb:PopupMenu.Items>
         </dxb:PopupMenu>
        <Style TargetType="{x:Type ListBoxItem}" x:Key="MenuListBoxItem" 
               BasedOn="{StaticResource NozzleListBoxItem}">
            <Setter Property="dxb:BarManager.DXContextMenu" Value="{StaticResource Menu}"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
        </Style>
    </UserControl.Resources>

    <Grid>

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid x:Name="grid">

            <Grid.ColumnDefinitions>
                <ColumnDefinition/>
                <ColumnDefinition Width="5"/>
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>

            <Border CornerRadius="10"
                    BorderBrush="#B0B0B0"
                    BorderThickness="2"
                    Padding="5">

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <dxga:DigitalGaugeControl Grid.Row="0"
                                              Height="30"
                                              HorizontalAlignment="Right"
                                              VerticalAlignment="Top"
                                              Text="{Binding SelectedNozzle.FuelSale.Sum, StringFormat=F2, FallbackValue=0.00}"
                                              Style="{StaticResource BaseDigitalScreenStyle}"
                                              Margin="0 0 0 2"/>

                    <dxga:DigitalGaugeControl Grid.Row="1" 
                                              Height="30"
                                              HorizontalAlignment="Right"
                                              VerticalAlignment="Top"
                                              Style="{StaticResource BaseDigitalScreenStyle}"
                                              Text="{Binding SelectedNozzle.FuelSale.Quantity, StringFormat=F2, FallbackValue=0.00}"
                                              Margin="0 0 0 2"/>


                    <dxga:DigitalGaugeControl Grid.Row="3" 
                                              SymbolCount="12"
                                              HorizontalAlignment="Right"
                                              VerticalAlignment="Top"
                                              Height="15"
                                              Style="{StaticResource BaseDigitalScreenStyle}"
                                              Text="{Binding SelectedNozzle.SalesSum, StringFormat=F2, FallbackValue=0.00}"
                                              Margin="0 2 0 0"/>

                </Grid>

            </Border>

            <Border CornerRadius="10"
                    BorderBrush="#B0B0B0"
                    BorderThickness="2"
                    Padding="5"
                    Grid.Column="2">

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <dxga:DigitalGaugeControl Grid.Row="0"
                                              Height="30"
                                              HorizontalAlignment="Right"
                                              VerticalAlignment="Top"
                                              Text="{Binding SelectedNozzle.ReceivedSum, StringFormat=F2, FallbackValue=0.00}"
                                              Style="{StaticResource DefaultDigitalScreenStyle}"
                                              Margin="0 0 0 2"/>

                    <dxga:DigitalGaugeControl Grid.Row="1" 
                                              Height="30"
                                              HorizontalAlignment="Right"
                                              VerticalAlignment="Top"
                                              Style="{StaticResource DefaultDigitalScreenStyle}"
                                              Text="{Binding SelectedNozzle.ReceivedQuantity, StringFormat=F2, FallbackValue=0.00}"
                                              Margin="0 0 0 2"/>


                    <dxga:DigitalGaugeControl Grid.Row="3" 
                                              SymbolCount="12"
                                              HorizontalAlignment="Right"
                                              VerticalAlignment="Top"
                                              Height="15"
                                              Style="{StaticResource DefaultDigitalScreenStyle}"
                                              Text="{Binding SelectedNozzle.LastCounter, StringFormat=F2, FallbackValue=0.00}"
                                              Margin="0 2 0 0"/>

                </Grid>

            </Border>

        </Grid>

        <TextBlock Text="{Binding SelectedNozzle.FuelSale.PaymentType, Converter={StaticResource EnumToStringConvertert}}"
                   TextAlignment="Center"
                   FontSize="18"
                   FontWeight="Bold"
                   dxb:BarManager.DXContextMenu="{StaticResource Menu}"
                   Grid.Row="1"/>

        <ListBox x:Name="listBox"
                 Background="Transparent"
                 SelectionMode="Single" 
                 IsEnabled="{Binding CanSelectedNozzle}"
                 ItemContainerStyle="{StaticResource MenuListBoxItem}"
                 SelectedItem="{Binding SelectedNozzle}"
                 Style="{StaticResource NozzleListBox}"
                 ItemsSource="{Binding Nozzles}"
                 Grid.Row="2">
            <dxmvvm:Interaction.Behaviors>
                <dxmvvm:EventToCommand EventName="MouseDoubleClick"
                                       Command="{Binding NozzleMouseDoubleClickCommand}"/>
                <dxmvvm:EventToCommand Event="PreviewMouseDown"
                                       Command="{Binding NozzleMouseDownCommand}"
                                       PassEventArgsToCommand="True" />
            </dxmvvm:Interaction.Behaviors>
        </ListBox>

    </Grid>

</UserControl>
