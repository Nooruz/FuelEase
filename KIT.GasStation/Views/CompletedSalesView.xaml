<base:BaseView
    x:Class="KIT.GasStation.Views.CompletedSalesView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:base="clr-namespace:KIT.GasStation.Views.Base"
    xmlns:dx="http://schemas.devexpress.com/winfx/2008/xaml/core"
    xmlns:dxb="http://schemas.devexpress.com/winfx/2008/xaml/bars"
    xmlns:dxe="http://schemas.devexpress.com/winfx/2008/xaml/editors"
    xmlns:dxg="http://schemas.devexpress.com/winfx/2008/xaml/grid"
    xmlns:dxlc="http://schemas.devexpress.com/winfx/2008/xaml/layoutcontrol"
    Width="1200"
    Height="700">

    <dxlc:LayoutControl Orientation="Vertical">

        <dxlc:GroupBox Header="Продажи">

            <dxg:GridControl
                ItemsSource="{Binding FuelSales}"
                SelectedItem="{Binding SelectedFuelSale}"
                ShowLoadingPanel="{Binding ShowLoadingPanel}">
                <dxg:GridControl.View>
                    <dxg:TableView
                        AllowEditing="False"
                        ShowGroupPanel="False"
                        ShowTotalSummary="True">
                        <dxg:TableView.RowCellMenuCustomizations>
                            <dxb:BarButtonItem
                                BarItemDisplayMode="ContentAndGlyph"
                                Command="{Binding DataContext.ReturnCommand, RelativeSource={RelativeSource AncestorType={x:Type base:BaseView}, Mode=FindAncestor}}"
                                Content="Возврат товара ККМ"
                                Glyph="{dx:DXImage SvgImages/Outlook Inspired/Reset.svg}" />
                        </dxg:TableView.RowCellMenuCustomizations>
                    </dxg:TableView>
                </dxg:GridControl.View>

                <dxg:GridColumn FieldName="CreateDate" Header="Дата и время">
                    <dxg:GridColumn.EditSettings>
                        <dxe:DateEditSettings Mask="G" MaskUseAsDisplayFormat="True" />
                    </dxg:GridColumn.EditSettings>
                </dxg:GridColumn>
                <dxg:GridColumn FieldName="Number" Header="№">
                    <dxg:GridColumn.EditSettings>
                        <dxe:TextEditSettings Mask="D4" />
                    </dxg:GridColumn.EditSettings>
                </dxg:GridColumn>
                <dxg:GridColumn FieldName="Shift.User.FullName" Header="Пользователь" />
                <dxg:GridColumn Binding="{Binding PaymentType, Converter={StaticResource EnumToStringConvertert}}" Header="Тип оплаты" />
                <dxg:GridColumn FieldName="Nozzle.Name" Header="Отпуск" />
                <dxg:GridColumn FieldName="Tank.Fuel.Name" Header="Топливо" />
                <dxg:GridColumn FieldName="Tank.Fuel.Price" Header="Цена" />
                <dxg:GridColumn FieldName="Sum" Header="Сумма" />
                <dxg:GridColumn FieldName="ReceivedSum" Header="Сумма (отпущено)" />
                <dxg:GridColumn FieldName="Quantity" Header="Кол-во" />
                <dxg:GridColumn FieldName="ReceivedQuantity" Header="Кол-во (отпущено)" />

                <dxg:GridControl.TotalSummary>
                    <dxg:GridSummaryItem FieldName="Sum" SummaryType="Sum" />
                    <dxg:GridSummaryItem FieldName="ReceivedSum" SummaryType="Sum" />
                    <dxg:GridSummaryItem FieldName="Quantity" SummaryType="Sum" />
                    <dxg:GridSummaryItem FieldName="ReceivedQuantity" SummaryType="Sum" />
                </dxg:GridControl.TotalSummary>

            </dxg:GridControl>

        </dxlc:GroupBox>

        <dxlc:GroupBox Height="200" Header="Фискальные чеки (ККМ)">

            <dxlc:LayoutGroup Orientation="Vertical">
                <dxg:GridControl ItemsSource="{Binding SelectedFuelSale.FiscalDatas}" SelectedItem="{Binding SelectedFiscalData}">
                    <dxg:GridControl.View>
                        <dxg:TableView AllowEditing="False" ShowGroupPanel="False" />
                    </dxg:GridControl.View>

                    <dxg:GridColumn FieldName="FiscalDocument" Header="ФД" />
                    <dxg:GridColumn FieldName="Quantity" Header="Кол-во" />
                    <dxg:GridColumn FieldName="Total" Header="Сумма" />
                    <dxg:GridColumn FieldName="OperationType" Header="Вид оплаты">
                        <dxg:GridColumn.EditSettings>
                            <dxe:ComboBoxEditSettings
                                DisplayMember="Value"
                                ItemsSource="{Binding OperationTypes}"
                                ValueMember="Key" />
                        </dxg:GridColumn.EditSettings>
                    </dxg:GridColumn>
                </dxg:GridControl>

                <dxlc:LayoutGroup VerticalAlignment="Bottom">

                    <Button
                        HorizontalAlignment="Right"
                        Command="{Binding ReturnCommand}"
                        Content="Возврат ККМ" />
                    <Button
                        HorizontalAlignment="Right"
                        Command="{Binding CloseCommand}"
                        Content="Закрыть" />

                </dxlc:LayoutGroup>
            </dxlc:LayoutGroup>


        </dxlc:GroupBox>

    </dxlc:LayoutControl>

</base:BaseView>
